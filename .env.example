# Site URL for production
SITE_URL=https://isaacavazquez.com
GOOGLE_SITE_VERIFICATION=your-search-console-verification-token

# Google Analytics 4 — leave unset to disable analytics entirely (dev / CI /
# tests). When set to a real measurement id (G-XXXXXXXXXX) gtag.js loads and the
# CSP widens to allow Google's endpoints. See /analytics-reference for the
# catalogue of tracked events.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Admin Credentials
ADMIN_USERNAME=your-admin-username-here
ADMIN_PASSWORD=your-secure-password-here

# Fantasy Football API
FANTASYPROS_API_KEY=your-api-key-here

# Premier League Data API
FOOTBALL_DATA_API_TOKEN=your-football-data-api-token-here

# Score pools — both optional; used only by `npm run update:score-pools`,
# never at runtime. Without them the snapshot builds from manual/CSV entries.
# The Odds API (the-odds-api.com): moneyline + totals odds with timestamps.
THE_ODDS_API_KEY=your-odds-api-key-here
# API-Football (api-sports.io): fixtures, results, standings, injuries, lineups.
API_FOOTBALL_KEY=your-api-football-key-here

# SpaceX / Launch Library 2 (thespacedevs) — optional.
# Anonymous requests are heavily rate limited (shared CI IPs get 429'd fast),
# which silently freezes the snapshot. A free account token raises the limit.
# Used only by `npm run update:spacex` / `update:spacex-images`; not needed at runtime.
SPACEDEVS_API_TOKEN=your-spacedevs-api-token-here

# BART API — optional. Falls back to BART's published demo key when unset.
# A personal key is free (https://api.bart.gov/api/register.aspx) and keeps the
# transit surface working if BART rotates the shared demo key. Used by the
# request-time transit refresh and `npm run update:bay-area-transit`.
BART_API_KEY=your-bart-api-key-here

# Cron Job Secret (for scheduled updates)
CRON_SECRET=your-cron-secret-here

# Resend – transactional email for MBA internship digest
RESEND_API_KEY=your-resend-api-key-here
MBA_DIGEST_ALLOWED_RECIPIENTS=you@example.com,@example.edu
