:\"https://isaacavazquez.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Contact\",\"item\":\"https://isaacavazquez.com/contact\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ContactPage\",\"name\":\"Contact Isaac Vazquez\",\"description\":\"Reach out to discuss product management opportunities, fintech product work, or analytics-driven platform initiatives with Isaac Vazquez.\",\"url\":\"https://isaacavazquez.com/contact\",\"mainEntity\":{\"@type\":\"Person\",\"name\":\"Isaac Vazquez\",\"email\":\"IsaacVazquez@berkeley.edu\",\"url\":\"https://isaacavazquez.com\"}}</script><div class=\"min-h-screen w-full bg-[var(--surface-primary)] page-section\"><div class=\"page-shell-tight\"><div class=\"space-y-6\"><div class=\"mx-auto max-w-4xl text-center\"><div class=\"space-y-4 mx-auto text-center items-center max-w-4xl\"><div class=\"flex justify-center\"><span class=\"section-kicker\">Contact</span></div><h1 class=\"font-bold tracking-tight text-[var(--text-primary)] text-4xl sm:text-5xl lg:text-6xl leading-[1.02]\">Get in touch.</h1><p class=\"text-sm lg:text-base font-normal text-[var(--text-secondary)] leading-relaxed max-inline-size-prose section-subtitle mb-0 mx-auto\">If you&#x27;re working on product, analytics, or investment-focused tools, I&#x27;d be glad to connect.</p></div></div><div class=\"space-y-6\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-10 sm:p-12 lg:p-16 w-full text-center shadow-sm\" role=\"article\"><div class=\"space-y-4\"><p class=\"text-sm font-semibold uppercase tracking-[0.16em] text-[var(--text-tertiary)]\">Good fit</p><h2 class=\"text-3xl font-bold text-[var(--text-primary)]\">Roles and projects where product judgment and execution both matter.</h2></div><p class=\"mb-6 mt-4 max-w-2xl mx-auto text-base md:text-lg text-[var(--text-secondary)] leading-relaxed\">I&#x27;m especially interested in analytics, fintech, workflow, and decision-support products, along with teams that care about clear strategy, reliable delivery, and practical product thinking.</p><div class=\"flex flex-col sm:flex-row gap-4 justify-center mb-6\"><a class=\"inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary)] active:scale-[0.98] bg-[var(--color-primary)] hover:bg-[var(--color-secondary)] text-white shadow-sm hover:shadow-md px-8 py-3.5 text-lg min-h-[52px] gap-2.5 w-full sm:w-auto\" href=\"mailto:IsaacVazquez@berkeley.edu\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg>Email me</a><a href=\"https://www.linkedin.com/in/isaac-vazquez\" class=\"inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary)] active:scale-[0.98] border border-[var(--neutral-300)] text-[var(--text-primary)] hover:bg-[var(--neutral-200)] dark:hover:bg-[var(--neutral-300)] hover:border-[var(--neutral-400)] px-8 py-3.5 text-lg min-h-[52px] gap-2.5 w-full sm:w-auto\" target=\"_blank\" rel=\"noopener noreferrer\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\"><path d=\"M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z\"></path><path d=\"M8 11l0 5\"></path><path d=\"M8 8l0 .01\"></path><path d=\"M12 16l0 -5\"></path><path d=\"M16 16v-3a2 2 0 0 0 -4 0\"></path></svg>Connect on LinkedIn</a></div><div class=\"flex items-center justify-center gap-2 text-sm text-[var(--color-success)]\"><div class=\"w-2 h-2 bg-[var(--color-success)] rounded-full animate-pulse\" aria-hidden=\"true\"></div><span>Based in Berkeley and available by email or LinkedIn</span></div></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12 w-full shadow-sm\" role=\"article\"><div class=\"text-center\"><div class=\"flex items-center justify-center gap-2 mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 text-[var(--color-primary)]\"><path d=\"M12 21s-6 -5.33 -6 -11a6 6 0 1 1 12 0c0 5.67 -6 11 -6 11z\"></path><path d=\"M12 11a2 2 0 1 0 0 -4a2 2 0 0 0 0 4z\"></path></svg><h3 class=\"text-xl font-bold text-[var(--text-primary)]\">Berkeley, CA</h3></div><p class=\"text-base text-[var(--text-secondary)] max-w-2xl mx-auto leading-relaxed\">Based in the Bay Area while attending UC Berkeley Haas. I enjoy working on products that help people make clearer decisions, whether the setting is civic tech, SaaS operations, or investment research.</p></div></div></div></div></div></div><!--$--><!--/$--></main></div><footer role=\"contentinfo\" aria-label=\"Site footer\" data-footer-variant=\"compact\" class=\"relative z-20 border-t border-[var(--border-primary)] bg-[var(--surface-primary)]\"><div class=\"page-shell py-8 md:py-10\"><div class=\"flex flex-col gap-5 border-t pt-6 sm:flex-row sm:items-center sm:justify-between border-[var(--border-primary)]\"><div class=\"space-y-1 text-sm text-[var(--text-tertiary)]\"><p class=\"font-medium text-[var(--text-primary)]\">Isaac Vazquez</p><p>Product management, projects, and analytics-focused work.</p></div><div class=\"flex flex-col gap-4 sm:items-end\"><nav aria-label=\"So