face-secondary)] hover:text-[var(--text-primary)]\" href=\"/investments\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 12m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M9 8m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v10a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M15 4m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path></svg><span>Investments</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/resume\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M14 3v4a1 1 0 0 0 1 1h4\"></path><path d=\"M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z\"></path><path d=\"M9 9l1 0\"></path><path d=\"M9 13l6 0\"></path><path d=\"M9 17l6 0\"></path></svg><span>Resume</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/contact\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg><span>Contact</span></a></li></ul></div></div></div></header><div class=\"min-h-screen\"><main id=\"main-content\" role=\"main\" aria-label=\"Isaac Vazquez Portfolio Homepage\" tabindex=\"-1\"><main class=\"min-h-screen w-full scroll-smooth bg-[var(--surface-primary)]\" id=\"main-content\" aria-label=\"Isaac Vazquez - Product Manager Portfolio\"><header><section class=\"relative overflow-hidden bg-[var(--surface-primary)] py-16 md:py-20 lg:py-24\" aria-label=\"Isaac Vazquez - product manager portfolio\" data-testid=\"hero\"><div class=\"absolute inset-0 pointer-events-none\"><div class=\"absolute inset-x-0 top-0 h-40 bg-gradient-to-b to-transparent\" style=\"background-image:linear-gradient(to bottom, color-mix(in srgb, var(--color-primary) 8%, transparent), transparent)\"></div></div><div class=\"page-shell relative z-10\"><div class=\"grid items-center gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:gap-16\"><div class=\"space-y-7\"><div class=\"space-y-5\"><span class=\"section-kicker\">Product manager portfolio</span><h1 class=\"max-w-4xl text-5xl font-bold tracking-tight text-[var(--text-primary)] sm:text-6xl lg:text-7xl lg:leading-[1.04]\">Building thoughtful products with a foundation in QA, analytics, and execution.</h1><p class=\"max-w-2xl text-lg leading-relaxed text-[var(--text-secondary)] md:text-xl\">I work across product strategy, research, and delivery, with experience spanning high-scale SaaS platforms, analytics projects, and investment research tools.</p></div><div class=\"flex flex-wrap gap-4\"><a class=\"inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary)] active:scale-[0.98] bg-[var(--color-primary)] hover:bg-[var(--color-secondary)] text-white shadow-sm hover:shadow-md px-8 py-3.5 text-lg min-h-[52px] gap-2.5\" href=\"/portfolio\">View projects</a><a class=\"inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary)] active:scale-[0.98] border border-[var(--neutral-300)] text-[var(--text-primary)] hover:bg-[var(--neutral-200)] dark:hover:bg-[var(--neutral-300)] hover:border-[var(--neutral-400)] px-8 py-3.5 text-lg min-h-[52px] gap-2.5\" href=\"/about\">Learn more</a></div></div><div class=\"relative order-first lg:order-last\"><div class=\"section-panel relative overflow-hidden p-4 sm:p-5\"><div class=\"relative aspect-[4/5] overflow-hidden rounded-[1.25rem] border border-[var(--border-primary)] shadow-lg\"><img alt=\"Isaac Vazquez - Technical Product Manager and UC Berkeley Haas MBA Candidate\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover object-top\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(min-width: 1024px) 38vw, 100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=2048&amp;q=75 2048w\" src=\"/_next/image?url=%2Fimages%2Fheadshot-new.png&amp;w=2048&amp;q=75\"/></div></div></div></div></div></section></header><section class=\"page-section bg-[var(--surface-primary)]\" aria-label=\"Projects\"><div class=\"page-shell\"><div><div class=\"mb-10\"><div class=\"space-y-4 max-w-3xl\"><div class=\"\"><span class=\"section-kicker\">Projects</span></div><h1 class=\"font-bold tracking-tight text-[var(--text-primary)] text-3xl sm:text-4xl lg:text-5xl leading-tight\">Investment Analytics Platform, Transforming Client Reporting into Self-Service Analytics, Scaling a Platform to 60M+ Users, and SpaceX Mission Control.</h1><p class=\"text-sm lg:text-base font-normal text-[var(--text-secondary)] leading-relaxed max-inline-size-prose section-subtitle mb-0\">These examples show the kinds of problems I like working on, from high-scale systems to data and investment research experiences.</p></div></div><div class=\"mb-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3\"><a href=\"/investments\"><div class=\"rounded-xl border transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-8 sm:p-10 lg:p-12 h-full group border-[var(--border-primary)] bg-[var(--surface-elevated)] shadow-sm\" role=\"article\"><div class=\"space-y-5\"><div class=\"flex items-center justify-between gap-3\"><span class=\"section-kicker\">Project</span><span class=\"text-xs font-medium uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">2025</span></div><h3 class=\"font-bold text-xl text-[var(--text-primary)] group-hover:text-[var(--color-primary)] transition-colors\">Investment Analytics Platform</h3><p class=\"text-sm leading-relaxed text-[var(--text-secondary)] line-clamp-3\">Full-stack investment platform with live Yahoo Finance data — portfolio tracking, gain/loss analytics, and side-by-side stock comparison with 30+ metrics and analyst consensus ratings.</p><div class=\"flex flex-wrap gap-2\"></div><div class=\"flex items-center justify-between gap-3 border-t border-[var(--border-primary)] pt-4\"><p class=\"text-xs font-semibold uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">Live data · 30+ metrics per stock · Analyst consensus ratings</p><div class=\"flex items-center gap-2 text-sm font-medium text-[var(--color-primary)]\">View project<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4 transition-transform group-hover:translate-x-1\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></div></div></div></div></a><a href=\"/portfolio/data-analytics-dashboard\"><div class=\"rounded-xl border transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-8 sm:p-10 lg:p-12 h-full group border-[var(--border-primary)] bg-[var(--surface-elevated)] shadow-sm\" role=\"article\"><div class=\"space-y-5\"><div class=\"flex items-center justify-between gap-3\"><span class=\"section-kicker\">Project</span><span class=\"text-xs font-medium uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">4 months (2020-2021)</span></div><h3 class=\"font-bold text-xl text-[var(--text-primary)] group-hover:text-[var(--color-primary)] transition-colors\">Transforming Client Reporting into Self-Service Analytics</h3><p class=\"text-sm leading-relaxed text-[var(--text-secondary)] line-clamp-3\">Led a product initiative replacing manual Excel reporting with automated real-time dashboards, enabling the company to scale from 15 to 45 clients without adding headcount.</p><div class=\"flex flex-wrap gap-2\"><div class=\"inline-flex items-center rounded-md font-medium transition-colors border border-[var(--border-primary)] text-[var(--text-secondary)] px-2 py-0.5 text-xs\">40% faster<!-- --> <!-- -->Decision Speed</div><div class=\"inline-flex items-center rounded-md font-medium transition-colors border border-[var(--border-primary)] text-[var(--text-secondary)] px-2 py-0.5 text-xs\">25% increase<!-- --> <!-- -->Conversion Rate</div><div class=\"inline-flex items-center rounded-md font-medium transition-colors border border-[var(--border-primary)] text-[var(--text-secondary)] px-2 py-0.5 text-xs\">60 hours/month<!-- --> <!-- -->Time Saved</div></div><div class=\"flex items-center justify-between gap-3 border-t border-[var(--border-primary)] pt-4\"><p class=\"text-xs font-semibold uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">40% faster decisions · 25% conversion lift</p><div class=\"flex items-center gap-2 text-sm font-medium text-[var(--color-primary)]\">View project<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4 transition-transform group-hover:translate-x-1\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></div></div></div></div></a><a href=\"/portfolio/civic-engagement-platform\"><div class=\"rounded-xl border transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-8 sm:p-10 lg:p-12 h-full group border-[var(--border-primary)] bg-[var(--surface-elevated)] shadow-sm\" role=\"article\"><div class=\"space-y-5\"><div class=\"flex items-center justify-between gap-3\"><span class=\"section-kicker\">Project</span><span class=\"text-xs font-medium uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">8 months (2022)</span></div><h3 class=\"font-bold text-xl text-[var(--text-primary)] group-hover:text-[var(--color-primary)] transition-colors\">Scaling a Platform to 60M+ Users</h3><p class=\"text-sm leading-relaxed text-[var(--text-secondary)] line-clamp-3\">Led product strategy and quality for a high-scale SaaS platform during the 2022 midterm elections, achieving 99.9% uptime while scaling from 5M to 60M+ users.</p><div class=\"flex flex-wrap gap-2\"><div class=\"inline-flex items-center rounded-md font-medium transition-colors border border-[var(--border-primary)] text-[var(--text-secondary)] px-2 py-0.5 text-xs\">60M+<!-- --> <!-- -->Users Reached</div><div class=\"inline-flex items-center rounded-md font-medium transition-colors border border-[var(--border-primary)] text-[var(--text-secondary)] px-2 py-0.5 text-xs\">99.9%<!-- --> <!-- -->Uptime Achieved</div><div class=\"inline-flex items-center rounded-md font-medium transition-colors border border-[var(--border-primary)] text-[var(--text-secondary)] px-2 py-0.5 text-xs\">30% faster<!-- --> <!-- -->Release Velocity</div></div><div class=\"flex items-center justify-between gap-3 border-t border-[var(--border-primary)] pt-4\"><p class=\"text-xs font-semibold uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">99.9% uptime · 30% faster releases</p><div class=\"flex items-center gap-2 text-sm font-medium text-[var(--color-primary)]\">View project<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4 transition-transform group-hover:translate-x-1\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></div></div></div></div></a><a href=\"/spacex-mission-control\"><div class=\"rounded-xl border transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-8 sm:p-10 lg:p-12 h-full group border-[var(--border-primary)] bg-[var(--surface-elevated)] shadow-sm\" role=\"article\"><div class=\"space-y-5\"><div class=\"flex items-center justify-between gap-3\"><span class=\"section-kicker\">Project</span><span class=\"text-xs font-medium uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">2026</span></div><h3 class=\"font-bold text-xl text-[var(--text-primary)] group-hover:text-[var(--color-primary)] transition-colors\">SpaceX Mission Control</h3><p class=\"text-sm leading-relaxed text-[var(--text-secondary)] line-clamp-3\">Mission-control-style SpaceX launch board with a next-launch hero, upcoming and past mission browsing, and deep-linked relationship-aware mission detail.</p><div class=\"flex flex-wrap gap-2\"></div><div class=\"flex items-center justify-between gap-3 border-t border-[var(--border-primary)] pt-4\"><p class=\"text-xs font-semibold uppercase tracking-[0.12em] text-[var(--text-tertiary)]\">Live API surface · deep-linked mission detail</p><div class=\"flex items-center gap-2 text-sm font-medium text-[var(--color-primary)]\">View project<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4 transition-transform group-hover:translate-x-1\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></div></div></div></div></a></div><div class=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between\"><p class=\"text-sm leading-relaxed text-[var(--text-secondary)]\">A broader set of product and analytics work lives in the projects section.</p><a class=\"inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary)] active:scale-[0.98] border border-[var(--neutral-300)] text-[var(--text-primary)] hover:bg-[var(--neutral-200)] dark:hover:bg-[var(--neutral-300)] hover:border-[var(--neutral-400)] px-8 py-3.5 text-lg min-h-[52px] gap-2.5\" href=\"/portfolio\">View all projects</a></div></div></div></section><section class=\"page-section bg-[var(--surface-secondary)]\" aria-label=\"How I think about product\"><div class=\"page-shell\"><div><div class=\"mb-10\"><div class=\"space-y-4 max-w-3xl\"><div class=\"\"><span class=\"section-kicker\">How I think</span></div><h1 class=\"font-bold tracking-tight text-[var(--text-primary)] text-3xl sm:text-4xl lg:text-5xl leading-tight\">How I approach product work.</h1><p class=\"text-sm lg:text-base font-normal text-[var(--text-secondary)] leading-relaxed max-inline-size-prose section-subtitle mb-0\">The themes stay pretty consistent: understand the problem clearly, use data thoughtfully, and keep execution tied to real outcomes.</p></div></div><div class=\"grid gap-6 md:grid-cols-2 lg:grid-cols-4\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12 h-full shadow-sm\" role=\"article\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"mb-4 h-8 w-8 text-[var(--color-primary)]\"><path d=\"M8.5 8.5m-5 0a5 5 0 1 0 10 0a5 5 0 1 0 -10 0\"></path><path d=\"M17 17l-3.5 -3.5\"></path></svg><h3 class=\"mb-3 text-lg font-bold text-[var(--text-primary)]\">Discovery &amp; Research</h3><p class=\"text-[var(--text-secondary)]\">I start with users, context, and the problem itself before jumping into solutions.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12 h-full shadow-sm\" role=\"article\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"mb-4 h-8 w-8 text-[var(--color-primary)]\"><path d=\"M4 6c0 -1.657 3.582 -3 8 -3s8 1.343 8 3s-3.582 3 -8 3s-8 -1.343 -8 -3\"></path><path d=\"M4 6v6c0 1.657 3.582 3 8 3s8 -1.343 8 -3v-6\"></path><path d=\"M4 12v6c0 1.657 3.582 3 8 3s8 -1.343 8 -3v-6\"></path></svg><h3 class=\"mb-3 text-lg font-bold text-[var(--text-primary)]\">Data-Informed Decisions</h3><p class=\"text-[var(--text-secondary)]\">I use data to sharpen judgment, validate assumptions, and understand whether the work is moving the right metrics.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12 h-full shadow-sm\" role=\"article\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"mb-4 h-8 w-8 text-[var(--color-primary)]\"><path d=\"M12 12m-8 0a8 8 0 1 0 16 0a8 8 0 1 0 -16 0\"></path><path d=\"M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0\"></path><path d=\"M12 12l7 -7\"></path><path d=\"M16 5h3v3\"></path></svg><h3 class=\"mb-3 text-lg font-bold text-[var(--text-primary)]\">Strategy &amp; Prioritization</h3><p class=\"text-[var(--text-secondary)]\">I care about choosing the right problems, narrowing scope thoughtfully, and helping teams stay aligned on outcomes.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12 h-full shadow-sm\" role=\"article\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"mb-4 h-8 w-8 text-[var(--color-primary)]\"><path d=\"M3 12m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M9 8m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v10a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M15 4m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path></svg><h3 class=\"mb-3 text-lg font-bold text-[var(--text-primary)]\">Execution &amp; Measurement</h3><p class=\"text-[var(--text-secondary)]\">I like building simple feedback loops so teams can ship, learn, and improve without losing sight of the bigger goal.</p></div></div></div></div></section><section id=\"contact\" class=\"page-section bg-[var(--surface-primary)]\"><div class=\"page-shell text-center\"><div><div class=\"mb-12\"><div class=\"space-y-4 mx-auto text-center items-center max-w-3xl\"><div class=\"flex justify-center\"><span class=\"section-kicker\">Contact</span></div><h1 class=\"font-bold tracking-tight text-[var(--text-primary)] text-3xl sm:text-4xl lg:text-5xl leading-tight\">Interested in working together?</h1><p class=\"text-sm lg:text-base font-normal text-[var(--text-secondary)] leading-relaxed max-inline-size-prose section-subtitle mb-0 mx-auto\">If you&#x27;re hiring for product work or want to talk through a project, I&#x27;d be glad to connect.</p></div></div><div class=\"mb-12 grid gap-6 md:grid-cols-3\"><a href=\"mailto:IsaacVazquez@berkeley.edu\" class=\"block\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-6 sm:p-8 h-full text-center shadow-sm\" role=\"article\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"mx-auto mb-4 h-10 w-10 text-[var(--color-primary)]\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg><h3 class=\"mb-2 text-lg font-bold text-[var(--text-primary)]\">Email</h3><span class=\"text-sm text-[var(--text-secondary)]\">IsaacVazquez@berkeley.edu</span></div></a><a href=\"https://linkedin.com/in/isaac-vazquez\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"block\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-6 sm:p-8 h-full text-center shadow-sm\" role=\"article\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"mx-auto mb-4 h-10 w-10 text-[var(--color-primary)]\"><path d=\"M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z\"></path><path d=\"M8 11l0 5\"></path><path d=\"M8 8l0 .01\"></path><path d=\"M12 16l0 -5\"></path><path d=\"M16 16v-3a2 2 0 0 0 -4 0\"></path></svg><h3 class=\"mb-2 text-lg font-bold text-[var(--text-pr