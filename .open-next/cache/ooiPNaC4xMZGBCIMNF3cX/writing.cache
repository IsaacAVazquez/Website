\",\"dateModified\":\"2025-01-24\",\"author\":{\"name\":\"Isaac Vazquez\",\"url\":\"https://isaacavazquez.com\"},\"publisher\":{\"@type\":\"Person\",\"name\":\"Isaac Vazquez\",\"url\":\"https://isaacavazquez.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://isaacavazquez.com/writing/building-reliable-software-systems\"},\"keywords\":[\"Software Quality\",\"System Architecture\",\"Testing\",\"Best Practices\",\"Reliability\",\"Maintainability\",\"Performance\",\"Austin Software Development\",\"Bay Area Engineering\",\"Business Strategy\",\"Product Management\",\"UC Berkeley MBA\"],\"articleSection\":\"Software Quality\",\"wordCount\":14300,\"inLanguage\":\"en-US\",\"url\":\"https://isaacavazquez.com/writing/building-reliable-software-systems\"}</script><div class=\"min-h-screen bg-[var(--surface-primary)] page-section\"><div class=\"page-shell-tight\"><div class=\"space-y-4 max-w-4xl\"><div class=\"\"><span class=\"section-kicker\">Writing</span></div><h1 class=\"font-bold tracking-tight text-[var(--text-primary)] text-4xl sm:text-5xl lg:text-6xl leading-[1.02]\">Notes on product strategy, operating systems, and analytics-heavy work.</h1><p class=\"text-sm lg:text-base font-normal text-[var(--text-secondary)] leading-relaxed max-inline-size-prose section-subtitle mb-0\">This is where I unpack the decisions behind the portfolio: product thinking, technical judgment, and lessons from building systems where trust matters.</p></div><div class=\"mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-2\"><a class=\"group\" href=\"/writing/building-a-fantasy-football-rankings-platform\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-[var(--border-accent)] cursor-pointer p-8 sm:p-10 lg:p-12 flex h-full flex-col shadow-sm\" role=\"article\"><div class=\"mb-3\"><span class=\"section-kicker\">Fantasy Football Analytics</span></div><h2 class=\"text-xl md: