ass=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M5 12l-2 0l9 -9l9 9l-2 0\"></path><path d=\"M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7\"></path><path d=\"M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6\"></path></svg><span>Home</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/about\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0\"></path><path d=\"M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2\"></path></svg><span>About</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/portfolio\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z\"></path><path d=\"M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2\"></path><path d=\"M12 12l0 .01\"></path><path d=\"M3 13a20 20 0 0 0 18 0\"></path></svg><span>Projects</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/investments\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 12m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M9 8m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v10a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M15 4m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path></svg><span>Investments</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/resume\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M14 3v4a1 1 0 0 0 1 1h4\"></path><path d=\"M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z\"></path><path d=\"M9 9l1 0\"></path><path d=\"M9 13l6 0\"></path><path d=\"M9 17l6 0\"></path></svg><span>Resume</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/contact\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg><span>Contact</span></a></li></ul></div></div></div></header><div class=\"min-h-screen\"><main id=\"main-content\" role=\"main\" aria-label=\"Portfolio Content\" tabindex=\"-1\"><div class=\"min-h-screen bg-[var(--surface-primary)] page-section\"><div class=\"page-shell\"><div class=\"mb-10\"><p class=\"section-kicker mb-4\">Fintech Tools</p><h1 class=\"text-4xl sm:text-5xl font-bold tracking-tight text-[var(--text-primary)] mb-4\">Interchange IQ</h1><p class=\"text-lg text-[var(--text-secondary)] max-w-2xl leading-relaxed mb-2\">Most merchants don&#x27;t know what they&#x27;re actually paying for payment processing — or why. Adjust the sliders to see how volume, average ticket size, and card mix affect total fees across major processors.</p><p class=\"text-sm text-[var(--text-tertiary)] max-w-2xl\">Interchange economics are at the core of every payments product. This tool models the real cost structure behind flat-rate and interchange+ pricing using published rate data.</p></div><div class=\"space-y-8\"><div class=\"grid grid-cols-2 sm:grid-cols-4 gap-3\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8 text-center\" role=\"article\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Monthly Volume</p><p class=\"text-base font-bold text-[var(--color-primary)] tabular-nums\">$50,000.00</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8 text-center\" role=\"article\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Avg Transaction</p><p class=\"text-base font-bold text-[var(--color-primary)] tabular-nums\">$85.00</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8 text-center\" role=\"article\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Lowest Cost Option</p><p class=\"text-base font-bold text-[var(--color-primary)] tabular-nums\">Stripe IC+</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8 text-center\" role=\"article\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Lowest Monthly Fee</p><p class=\"text-base font-bold text-[var(--color-primary)] tabular-nums\">$878.50</p></div></div><div class=\"grid lg:grid-cols-[320px_1fr] gap-8\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12 space-y-7 self-start\" role=\"article\"><h2 class=\"text-sm font-semibold text-[var(--text-primary)] flex items-center gap-2 uppercase tracking-[0.12em]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"tabler-icon tabler-icon-credit-card h-4 w-4 text-[var(--color-primary)]\"><path d=\"M3 8a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3l0 -8\"></path><path d=\"M3 10l18 0\"></path><path d=\"M7 15l.01 0\"></path><path d=\"M11 15l2 0\"></path></svg>Business Profile</h2><div class=\"space-y-2\"><div class=\"flex justify-between items-baseline gap-2\"><label class=\"text-sm font-medium text-[var(--text-primary)]\">Monthly Processing Volume</label><span class=\"text-sm font-semibold text-[var(--color-primary)] tabular-nums flex-shrink-0\">$50,000</span></div><input type=\"range\" min=\"1000\" max=\"500000\" step=\"1000\" class=\"w-full h-1.5 rounded-full appearance-none cursor-pointer\" style=\"background:linear-gradient(to right, var(--color-primary) 9.819639278557114%, var(--border-primary) 9.819639278557114%)\" value=\"50000\"/><p class=\"text-xs text-[var(--text-tertiary)]\">Total card revenue processed per month</p></div><div class=\"space-y-2\"><div class=\"flex justify-between items-baseline gap-2\"><label class=\"text-sm font-medium text-[var(--text-primary)]\">Average Transaction Size</label><span class=\"text-sm font-semibold text-[var(--color-primary)] tabular-nums flex-shrink-0\">$85</span></div><input type=\"range\" min=\"5\" max=\"500\" step=\"5\" class=\"w-full h-1.5 rounded-full appearance-none cursor-pointer\" style=\"background:linear-gradient(to right, var(--color-primary) 16.161616161616163%, var(--border-primary) 16.161616161616163%)\" value=\"85\"/><p class=\"text-xs text-[var(--text-tertiary)]\">Per-transaction fixed fees matter more at lower ticket sizes</p></div><div class=\"border-t border-[var(--border-primary)] pt-5 space-y-5\"><div class=\"flex items-center gap-2\"><span class=\"text-sm font-medium text-[var(--text-primary)]\">Card Mix</span><button aria-label=\"Learn about card mix\" class=\"text-[var(--text-tertiary)] hover:text-[var(--color-primary)] transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"tabler-icon tabler-icon-info-circle h-4 w-4\"><path d=\"M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0\"></path><path d=\"M12 9h.01\"></path><path d=\"M11 12h1v4h1\"></path></svg></button></div><div class=\"space-y-2\"><div class=\"flex justify-between items-baseline gap-2\"><label class=\"text-sm font-medium text-[var(--text-primary)]\">% Credit Cards (Visa / Mastercard)</label><span class=\"text-sm font-semibold text-[var(--color-primary)] tabular-nums flex-shrink-0\">65%</span></div><input type=\"range\" min=\"0\" max=\"100\" step=\"5\" class=\"w-full h-1.5 rounded-full appearance-none cursor-pointer\" style=\"background:linear-gradient(to right, var(--color-primary) 65%, var(--border-primary) 65%)\" value=\"65\"/><p class=\"text-xs text-[var(--text-tertiary)]\">Debit: 35% of all transactions</p></div><div class=\"space-y-2\"><div class=\"flex justify-between items-baseline gap-2\"><label class=\"text-sm font-medium text-[var(--text-primary)]\">% of Credit Cards that are Amex</label><span class=\"text-sm font-semibold text-[var(--color-primary)] tabular-nums flex-shrink-0\">18%</span></div><input type=\"range\" min=\"0\" max=\"50\" step=\"1\" class=\"w-full h-1.5 rounded-full appearance-none cursor-pointer\" style=\"background:linear-gradient(to right, var(--color-primary) 36%, var(--border-primary) 36%)\" value=\"18\"/><p class=\"text-xs text-[var(--text-tertiary)]\">Amex = 11.7% of total</p></div><div class=\"space-y-2 pt-1\"><div class=\"flex items-center gap-2 text-xs\"><div class=\"h-1.5 rounded-full bg-[var(--color-primary)] flex-shrink-0 min-w-[4px]\" style=\"width:53.300000000000004%;max-width:50%;opacity:0.7553333333333334\"></div><span class=\"text-[var(--text-secondary)]\">Visa/MC Credit<!-- -->: <span class=\"font-medium tabular-nums\">53.3<!-- -->%</span><span class=\"text-[var(--text-tertiary)] ml-1\">(<!-- -->~1.65% + $0.10<!-- -->)</span></span></div><div class=\"flex items-center gap-2 text-xs\"><div class=\"h-1.5 rounded-full bg-[var(--color-primary)] flex-shrink-0 min-w-[4px]\" style=\"width:35%;max-width:50%;opacity:0.6333333333333333\"></div><span class=\"text-[var(--text-secondary)]\">Debit (Reg E)<!-- -->: <span class=\"font-medium tabular-nums\">35.0<!-- -->%</span><span class=\"text-[var(--text-tertiary)] ml-1\">(<!-- -->~0.05% + $0.22<!-- -->)</span></span></div><div class=\"flex items-center gap-2 text-xs\"><div class=\"h-1.5 rounded-full bg-[var(--color-primary)] flex-shrink-0 min-w-[4px]\" style=\"width:11.7%;max-width:50%;opacity:0.47800000000000004\"></div><span class=\"text-[var(--text-secondary)]\">Amex<!-- -->: <span class=\"font-medium tabular-nums\">11.7<!-- -->%</span><span class=\"text-[var(--text-tertiary)] ml-1\">(<!-- -->~2.30%<!-- -->)</span></span></div></div></div></div><div class=\"space-y-5\"><div class=\"flex items-start gap-3 p-4 rounded-xl border border-[var(--color-success,#22c55e)]/25 bg-[var(--color-success,#22c55e)]/5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"tabler-icon tabler-icon-trending-down h-5 w-5 text-[var(--color-success,#22c55e)] flex-shrink-0 mt-0.5\"><path d=\"M3 7l6 6l4 -4l8 8\"></path><path d=\"M21 10l0 7l-7 0\"></path></svg><p class=\"text-sm text-[var(--text-primary)]\">At your volume, <strong>Stripe IC+</strong> saves<!-- --> <strong class=\"text-[var(--color-success,#22c55e)]\">$480.33<!-- -->/month</strong> <!-- -->(<!-- -->$5,763.94<!-- -->/year) vs. the best flat-rate option. Interchange+ becomes more attractive as volume scales.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12\" role=\"article\"><h2 class=\"text-sm font-semibold uppercase tracking-[0.12em] text-[var(--text-primary)] mb-5 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"tabler-icon tabler-icon-building-bank h-4 w-4 text-[var(--color-primary)]\"><path d=\"M3 21l18 0\"></path><path d=\"M3 10l18 0\"></path><path d=\"M5 6l7 -3l7 3\"></path><path d=\"M4 10l0 11\"></path><path d=\"M20 10l0 11\"></path><path d=\"M8 14l0 3\"></path><path d=\"M12 14l0 3\"></path><path d=\"M16 14l0 3\"></path></svg>Monthly Fee Comparison</h2><div class=\"space-y-5\"><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--color-primary)]\">Stripe IC+</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Interchange+</span><span class=\"text-xs px-1.5 py-0.5 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] font-medium whitespace-nowrap flex-shrink-0\">Cheapest</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--color-primary)]\">$878.50<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->1.76<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:43.20678431939823%;opacity:1;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Custom pricing; typically $250k+/yr volume</p></div><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--text-primary)]\">Checkout.com</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Interchange+</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--text-primary)]\">$878.50<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->1.76<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:43.20678431939823%;opacity:0.7785714285714286;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Enterprise tier; volume minimums apply</p></div><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--text-primary)]\">Adyen</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Interchange+</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--text-primary)]\">$921.14<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->1.84<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:45.30428178793577%;opacity:0.7071428571428571;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Processing markup + blended scheme fees</p></div><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--text-primary)]\">Square</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Flat Rate</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--text-primary)]\">$1,358.82<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->2.72<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:66.83060899754086%;opacity:0.6357142857142857;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Card-present; online is 2.9%+$0.30</p></div><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--text-primary)]\">Stripe</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Flat Rate</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--text-primary)]\">$1,626.47<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->3.25<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:79.99421380008678%;opacity:0.5642857142857143;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Standard online card rate</p></div><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--text-primary)]\">Shopify</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Flat Rate</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--text-primary)]\">$1,626.47<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->3.25<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:79.99421380008678%;opacity:0.4928571428571428;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Shopify Payments basic plan</p></div><div class=\"space-y-1.5\"><div class=\"flex items-center justify-between gap-3 flex-wrap\"><div class=\"flex items-center gap-2 min-w-0 flex-wrap\"><span class=\"text-sm font-medium truncate text-[var(--text-primary)]\">PayPal</span><span class=\"text-xs px-1.5 py-0.5 rounded-full border border-[var(--border-primary)] text-[var(--text-tertiary)] whitespace-nowrap flex-shrink-0\">Flat Rate</span></div><div class=\"text-right flex-shrink-0\"><span class=\"text-sm font-semibold tabular-nums text-[var(--text-primary)]\">$2,033.24<span class=\"font-normal text-[var(--text-tertiary)]\">/mo</span></span><span class=\"text-xs text-[var(--text-tertiary)] ml-2 tabular-nums\">(<!-- -->4.07<!-- -->% eff.)</span></div></div><div class=\"h-1.5 bg-[var(--surface-secondary)] rounded-full overflow-hidden\"><div class=\"h-full rounded-full transition-all duration-500 ease-out\" style=\"width:100%;opacity:0.42142857142857143;background-color:var(--color-primary)\"></div></div><p class=\"text-xs text-[var(--text-tertiary)]\">Standard checkout rate</p></div></div></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12\" role=\"article\"><h2 class=\"text-sm font-semibold uppercase tracking-[0.12em] text-[var(--text-primary)] mb-4 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"tabler-icon tabler-icon-arrow-right h-4 w-4 text-[var(--color-primary)]\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg>Annual Projection — Top 3</h2><div class=\"grid grid-cols-3 gap-3\"><div class=\"text-center p-3 rounded-xl bg-[var(--surface-secondary)]\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Stripe IC+</p><p class=\"text-xl font-bold tabular-nums text-[var(--color-primary)]\">$10.5k</p><p class=\"text-xs text-[var(--text-tertiary)] mt-0.5\">per year</p></div><div class=\"text-center p-3 rounded-xl bg-[var(--surface-secondary)]\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Checkout.com</p><p class=\"text-xl font-bold tabular-nums text-[var(--text-primary)]\">$10.5k</p><p class=\"text-xs text-[var(--text-tertiary)] mt-0.5\">per year</p></div><div class=\"text-center p-3 rounded-xl bg-[var(--surface-secondary)]\"><p class=\"text-xs text-[var(--text-tertiary)] mb-1\">Adyen</p><p class=\"text-xl font-bold tabular-nums text-[var(--text-primary)]\">$11.1k</p><p class=\"text-xs text-[var(--text-tertiary)] mt-0.5\">per year</p></div></div></div><div class=\"rounded-xl bg-[var(--surface-elevated)] p-8 sm:p-10 lg:p-12 border border-[var(--border-accent)]\" role=\"article\"><h2 class=\"text-sm font-semibold text-[var(--text-primary)] mb-2\">Breakeven: Stripe Flat vs. Stripe IC+</h2><p class=\"text-sm text-[var(--text-secondary)] leading-relaxed\">With your card mix, Stripe IC+ becomes cheaper than Stripe flat-rate when avg ticket exceeds<!-- --> <strong class=\"text-[var(--color-primary)] tabular-nums\">$<!-- -->14.14</strong>.<span> Your current avg ticket ($<!-- -->85<!-- -->) is <strong>above</strong> that — IC+ wins on unit economics.</span></p><p class=\"text-xs text-[var(--text-tertiary)] mt-2\">Note: Stripe IC+ requires a custom contract and typically $250k+/year in volume.</p></div></div></div><div class=\"border-t border-[var(--border-primary)] pt-8 space-y-6\"><h2 class=\"text-lg font-bold text-[var(--text-primary)]\">How Payment Processing Fees Work</h2><div class=\"grid md:grid-cols-3 gap-5\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12\" role=\"article\"><h3 class=\"text-sm font-semibold text-[var(--text-primary)] mb-2\">What is interchange?</h3><p class=\"text-sm text-[var(--text-secondary)] leading-relaxed\">Interchange is the fee the card-issuing bank charges every time a card is swiped or typed. It&#x27;s set by Visa and Mastercard — not your processor. It flows: Issuer ← Acquirer ← Merchant. Your processor doesn&#x27;t set it; they just pass it through (or bundle it into a flat rate).</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12\" role=\"article\"><h3 class=\"text-sm font-semibold text-[var(--text-primary)] mb-2\">Flat-rate vs. Interchange+</h3><p class=\"text-sm text-[var(--text-secondary)] leading-relaxed\">Flat-rate (e.g., 2.9% + $0.30) bundles interchange, network assessments, and processor markup into one predictable number. Interchange+ passes the actual interchange cost through to you and adds a transparent markup — which is cheaper at scale when your card mix is favorable.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-8 sm:p-10 lg:p-12\" role=\"article\"><h3 class=\"text-sm font-semibold text-[var(--text-primary)] mb-2\">Caveats &amp; real-world nuance</h3><p class=\"text-sm text-[var(--text-secondary)] leading-relaxed\">These are representative averages. Real interchange has 300+ rate categories by card type, industry code, and auth method. IC+ is typically available to merchants processing $250k+/yr. Card-present transactions have lower interchange than online. Always get actual quotes — this tool is directional, not definitive.</p></div></div><p class=\"text-xs text-[var(--text-tertiary)] text-center\">Interchange rates based on published 2024 Visa/Mastercard US schedules and Amex OptBlue program averages. Processor fees from public pricing pages. For educational purposes — actual rates vary by industry, card type, and negotiated terms.</p></div></div></div></div><!--$--><!--/$--></main></div><footer role=\"contentinfo\" aria-label=\"Site footer\" data-footer-variant=\"full\" class=\"relative z-20 border-t border-[var(--border-primary)] bg-[var(--surface-primary)]\"><div class=\"page-shell py-12 md:py-16\"><div class=\"rounded-[1.5rem] p-8 md:p-10 section-panel\"><div class=\"flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between\"><div class=\"space-y-4\"><h2 class=\"max-w-2xl text-3xl font-bold tracking-tight md:text-4xl text-[var(--text-primary)]\">Thanks for taking a look.</h2><p class=\"max-w-2xl text-lg leading-relaxed text-[var(--text-secondary)]\">If a project stands out, I&#x27;d be happy to share more about the work or my background.</p></div><div class=\"flex flex-col gap-3 sm:flex-row\"><a class=\"inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl px-6 py-3 font-medium transition-colors bg-[var(--text-primary)] text-[var(--text-inverse)] hover:bg-[var(--neutral-800)]\" href=\"/portfolio\">View projects<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></a><a class=\"inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl border px-6 py-3 font-medium transition-colors border-[var(--border-primary)] bg-[var(--surface-primary)] text-[var(--text-primary)] hover:bg-[var(--surface-secondary)]\" href=\"/contact\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg>Get in touch</a></div></div></div><div class=\"flex flex-col gap-5 border-t pt-6 sm:flex-row sm:items-center sm:justify-between mt-8 border-[var(--border-primary)]\"><div class=\"space-y-1 text-sm text-[var(--text-tertiary)]\"><p class=\"font-medium text-[var(--text-primary)]\">Isaac Vazquez</p><p>Product management, projects, and analytics-focused work.</p></div><div class=\"flex flex-