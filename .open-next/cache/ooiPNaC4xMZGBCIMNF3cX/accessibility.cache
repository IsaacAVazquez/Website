y)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M5 12l-2 0l9 -9l9 9l-2 0\"></path><path d=\"M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7\"></path><path d=\"M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6\"></path></svg><span>Home</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/about\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0\"></path><path d=\"M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2\"></path></svg><span>About</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/portfolio\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z\"></path><path d=\"M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2\"></path><path d=\"M12 12l0 .01\"></path><path d=\"M3 13a20 20 0 0 0 18 0\"></path></svg><span>Projects</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/investments\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 12m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M9 8m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v10a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M15 4m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path></svg><span>Investments</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/resume\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M14 3v4a1 1 0 0 0 1 1h4\"></path><path d=\"M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z\"></path><path d=\"M9 9l1 0\"></path><path d=\"M9 13l6 0\"></path><path d=\"M9 17l6 0\"></path></svg><span>Resume</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/contact\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg><span>Contact</span></a></li></ul></div></div></div></header><div class=\"min-h-screen\"><main id=\"main-content\" role=\"main\" aria-label=\"Portfolio Content\" tabindex=\"-1\"><div class=\"min-h-screen bg-[var(--surface-secondary)] page-section\"><div class=\"page-shell-tight\"><div class=\"mx-auto max-w-4xl\"><div class=\"mb-12\"><h1 class=\"sm:text-6xl font-bold tracking-tight mb-4 text-4xl md:text-5xl lg:text-6xl text-black dark:text-white\">Accessibility Statement</h1><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-600 dark:text-neutral-400\">Last updated: November 2025</p></div><div class=\"space-y-8\"><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Commitment to Accessibility</h2><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300\">Isaac Vazquez is committed to ensuring digital accessibility for people with disabilities. I am continually improving the user experience for everyone and applying the relevant accessibility standards to ensure this website is accessible to all.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Conformance Status</h2><p class=\"text-sm lg:text-base font-normal leading-relaxed max-inline-size-prose text-neutral-700 dark:text-neutral-300 mb-4\">The Web Content Accessibility Guidelines (WCAG) defines requirements for designers and developers to improve accessibility for people with disabilities. It defines three levels of conformance: Level A, Level AA, and Level AAA.</p><p class=\"text-sm lg:text-base leading-relaxed max-inline-size-prose text-neutral-700 dark:text-neutral-300 font-semibold mb-4\">isaacavazquez.com is fully conformant with WCAG 2.1 level AA and strives for AAA conformance.</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300 text-sm\">Fully conformant means that the content fully conforms to the accessibility standard without any exceptions.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Accessibility Features</h2><div class=\"space-y-3\"><div class=\"flex items-start gap-3\"><span class=\"text-xl\">⌨️</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Keyboard Navigation</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">All functionality is accessible via keyboard with clear focus indicators</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">🔊</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Screen Readers</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">Compatible with NVDA, JAWS, and VoiceOver with proper ARIA labels</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">🎨</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">High Contrast</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">21:1 contrast ratio for primary text (exceeds WCAG AAA standard of 7:1)</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">👆</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Touch Targets</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">Minimum 44px for mobile-friendly interaction (WCAG AAA compliant)</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">🎬</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Reduced Motion</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">Respects prefers-reduced-motion preferences for users sensitive to motion</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">🏗️</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Semantic HTML</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">Proper landmarks, heading structure, and semantic elements throughout</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">🖼️</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Alt Text</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">All images have meaningful alternative text for screen readers</p></div></div><div class=\"flex items-start gap-3\"><span class=\"text-xl\">🎯</span><div><p class=\"text-sm lg:text-base leading-relaxed mb-4 max-inline-size-prose font-semibold text-neutral-800 dark:text-neutral-200\">Focus Indicators</p><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-600 dark:text-neutral-400\">Clear visual focus indicators on all interactive elements</p></div></div></div></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Keyboard Shortcuts</h2><div class=\"space-y-2\"><div class=\"flex items-center justify-between py-2 border-b border-neutral-200 dark:border-neutral-700\"><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300\">Close modals and overlays</p><code class=\"px-3 py-1 bg-neutral-100 dark:bg-neutral-800 rounded-md text-sm font-mono text-black dark:text-white\">Escape</code></div><div class=\"flex items-center justify-between py-2 border-b border-neutral-200 dark:border-neutral-700\"><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300\">Navigate forward</p><code class=\"px-3 py-1 bg-neutral-100 dark:bg-neutral-800 rounded-md text-sm font-mono text-black dark:text-white\">Tab</code></div><div class=\"flex items-center justify-between py-2\"><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300\">Navigate backward</p><code class=\"px-3 py-1 bg-neutral-100 dark:bg-neutral-800 rounded-md text-sm font-mono text-black dark:text-white\">Shift+Tab</code></div></div></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Feedback</h2><p class=\"text-sm lg:text-base font-normal leading-relaxed max-inline-size-prose text-neutral-700 dark:text-neutral-300 mb-4\">I welcome your feedback on the accessibility of isaacavazquez.com. Please let me know if you encounter accessibility barriers:</p><div class=\"space-y-2\"><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300\"><strong>Email:</strong> <a href=\"mailto:IsaacVazquez@berkeley.edu\" class=\"text-black dark:text-white underline hover:text-neutral-600 dark:hover:text-neutral-300\">IsaacVazquez@berkeley.edu</a></p><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300\"><strong>Website:</strong> <a class=\"text-black dark:text-white underline hover:text-neutral-600 dark:hover:text-neutral-300\" href=\"/contact\">Contact Page</a></p></div><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300 mt-4 text-sm\">I aim to respond to feedback within 2 business days.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Technical Specifications</h2><p class=\"text-sm lg:text-base font-normal leading-relaxed max-inline-size-prose text-neutral-700 dark:text-neutral-300 mb-4\">Accessibility of isaacavazquez.com relies on the following technologies:</p><ul class=\"list-disc list-inside space-y-1 text-neutral-700 dark:text-neutral-300\"><li>HTML5</li><li>CSS3</li><li>JavaScript (React/Next.js)</li><li>ARIA (Accessible Rich Internet Applications)</li></ul><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300 mt-4 text-sm\">These technologies are relied upon for conformance with the accessibility standards used.</p></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Assessment Approach</h2><p class=\"text-sm lg:text-base font-normal leading-relaxed max-inline-size-prose text-neutral-700 dark:text-neutral-300 mb-4\">I assessed the accessibility of isaacavazquez.com by the following approaches:</p><ul class=\"list-disc list-inside space-y-1 text-neutral-700 dark:text-neutral-300\"><li>Self-evaluation and code review</li><li>Manual keyboard navigation testing</li><li>Contrast ratio analysis (21:1 for primary text)</li><li>Touch target measurement (44px minimum)</li><li>Reduced motion preference testing</li><li>Semantic HTML validation</li></ul></div><div class=\"rounded-xl bg-[var(--surface-elevated)] border border-[var(--border-primary)] p-6 sm:p-8\" role=\"article\"><h2 class=\"text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4 text-black dark:text-white\">Known Limitations</h2><p class=\"text-sm lg:text-base font-normal leading-relaxed max-inline-size-prose text-neutral-700 dark:text-neutral-300 mb-4\">Despite my best efforts to ensure accessibility, some areas for improvement remain. I am actively working to:</p><ul class=\"list-disc list-inside space-y-1 text-neutral-700 dark:text-neutral-300\"><li>Complete comprehensive screen reader testing with multiple assistive technologies</li><li>Achieve AAA contrast (7:1) for all text elements (currently: primary and secondary meet AAA, tertiary meets AA)</li><li>Expand public-facing keyboard shortcut documentation</li></ul><p class=\"text-sm lg:text-base font-normal leading-relaxed mb-4 max-inline-size-prose text-neutral-700 dark:text-neutral-300 mt-4\">If you encounter any accessibility barriers, please contact me so I can address them promptly.</p></div></div><div class=\"mt-12 pt-8 border-t border-neutral-200 dark:border-neutral-700\"><p class=\"lg:text-base font-normal mb-4 max-inline-size-prose text-sm text-neutral-500 dark:text-neutral-500 text-center\">This accessibility statement was created on November 2025 and reflects our ongoing commitment to digital accessibility. For more information about web accessibility, visit the<!-- --> <a href=\"https://www.w3.org/WAI/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"underline hover:text-black dark:hover:text-white\">W3C Web Accessibility Initiative (WAI)</a>.</p></div></div></div></div><!--$--><!--/$--></main></div><footer role=\"contentinfo\" aria-label=\"Site footer\" data-footer-variant=\"full\" class=\"relative z-20 border-t border-[var(--border-primary)] bg-[var(--surface-primary)]\"><div class=\"page-shell py-12 md:py-16\"><div class=\"rounded-[1.5rem] p-8 md:p-10 section-panel\"><div class=\"flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between\"><div class=\"space-y-4\"><h2 class=\"max-w-2xl text-3xl font-bold tracking-tight md:text-4xl text-[var(--text-primary)]\">Thanks for taking a look.</h2><p class=\"max-w-2xl text-lg leading-relaxed text-[var(--text-secondary)]\">If a project stands out, I&#x27;d be happy to share more about the work or my background.</p></div><div class=\"flex flex-col gap-3 sm:flex-row\"><a class=\"inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl px-6 py-3 font-medium transition-colors bg-[var(--text-primary)] text-[var(--text-inverse)] hover:bg-[var(--neutral-800)]\" href=\"/portfolio\">View projects<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></a><a class=\"inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl border px-6 py-3 font-medium transition-colors border-[var(--border-primary)] bg-[var(--surface-primary)] text-[var(--text-primary)] hover:bg-[var(--surface-secondary)]\" href=\"/contact\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg>Get in touch</a></div></div></div><div class=\"flex flex-col gap-5 border-t pt-6 sm:flex-row sm:items-center sm:justify-between mt-8 border-[var(--border-primary)]\"><div class=\"space-y-1 text-sm text-[var(--text-tertiary)]\"><p class=\"font-medium text-[var(--text-primary)]\">Isaac Vazquez</p><p>Product management, projects, and analytics-focused work.</p></div><div class=\"flex flex-col gap-4 sm:items-end\"><nav aria-label=\"Social media links\" class=\"flex items-center gap-2\"><a href=\"https://linkedin.com/in/isaac-vazquez\" aria-label=\"Visit Isaac Vazquez&#x27;s LinkedIn profile\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border transition-colors border-[var(--border-primary)] text-[var(--text-tertiary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" width=\"18\" height=\"18\" aria-hidden=\"true\"><path d=\"M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z\"></path><path d=\"M8 11l0 5\"></path><path d=\"M8 8l0 .01\"></path><path d=\"M12 16l0 -5\"></path><path d=\"M16 16v-3a2 2 0 0 0 -4 0\"></path></svg></a><a href=\"https://github.com/IsaacAVazquez\" aria-label=\"Visit Isaac Vazquez&#x27;s GitHub profile\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border transition-colors border-[var(--border-primary)] text-[var(--text-tertiary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" width=\"18\" height=\"18\" aria-hidden=\"true\"><path d=\"M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5\"></path></svg></a></nav><div class=\"flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--text-tertiary)]\"><span>2026</span><a class=\"transition-colors hover:text-[var(--text-primary)]\" href=\"/accessibility\">Accessibility</a><a href=\"https://isaacavazquez.com\" class=\"font-medium transition-colors text-[var(--text-primary)] hover:text-[var(--color-primary)]\">isaacavazquez.com</a></div></div></div></div></footer><script src=\"/_next/static/chunks/webpack-dd523bc6d663ffa9.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7106,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"5856\\\",\\\"static/chunks/5856-817fbea2f02f29bd.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-be1124ffefb0122c.js\\\"],\\\"Providers\\\"]\\n3:I[4665,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"5856\\\",\\\"static/chunks/5856-817fbea2f02f29bd.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-be1124ffefb0122c.js\\\"],\\\"StaticHeader\\\"]\\n4:I[9644,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"5856\\\",\\\"static/chunks/5856-817fbea2f02f29bd.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-be1124ffefb0122c.js\\\"],\\\"ConditionalLayout\\\"]\\n5:I[7121,[],\\\"\\\"]\\n6:I[4581,[],\\\"\\\"]\\n7:I[3693,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"2159\\\",\\\"static/chunks/2159-a2185eb42de1551d.js\\\",\\\"4345\\\",\\\"static/chunks/app/not-found-db6358576148c4d6.js\\\"],\\\"default\\\"]\\n12:I[7123,[],\\\"\\\"]\\n:HL[\\\"/_next/static/media/bb3ef058b751a6ad-s.p.woff2\\\",\\\"font\\\",{\\\"crossOrig