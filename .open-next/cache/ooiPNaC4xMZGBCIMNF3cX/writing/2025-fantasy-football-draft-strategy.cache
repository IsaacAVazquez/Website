l-scale=1\"}]]}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L3\",null,{\"children\":[\"$\",\"$4\",null,{\"name\":\"Next.Metadata\",\"children\":[[\"$\",\"title\",\"0\",{\"children\":\"Isaac Vazquez – Product Manager | UC Berkeley Haas MBA | Portfolio & Case Studies | Isaac Vazquez\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Dominate your fantasy football draft with advanced analytics and tier-based strategies. Expert insights on data-driven draft approaches for 2025.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"author\",\"href\":\"https://isaacavazquez.com\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"4\",{\"name\":\"creator\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"5\",{\"name\":\"publisher\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"7\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"meta\",\"8\",{\"name\":\"expertise\",\"content\":\"fantasy football draft 2025, fantasy draft strategy, fantasy football analytics, draft tiers, fantasy football data, NFL draft strategy\"}],[\"$\",\"meta\",\"9\",{\"name\":\"profession\",\"content\":\"Technical Product Manager\"}],[\"$\",\"meta\",\"10\",{\"name\":\"content-type\",\"content\":\"Article\"}],[\"$\",\"meta\",\"11\",{\"name\":\"summary\",\"content\":\"Dominate your fantasy football draft with advanced analytics and tier-based strategies. Expert insights on data-driven draft approaches for 2025.\"}],[\"$\",\"meta\",\"12\",{\"name\":\"article:published_time\",\"content\":\"2025-01-24\"}],[\"$\",\"meta\",\"13\",{\"name\":\"article:modified_time\",\"content\":\"2025-01-24\"}],[\"$\",\"meta\",\"14\",{\"name\":\"og:updated_time\",\"content\":\"2025-01-24\"}],[\"$\",\"link\",\"15\",{\"rel\":\"canonical\",\"href\":\"https://isaacavazquez.com/writing/2025-fantasy-football-draft-strategy\"}],[\"$\",\"link\",\"16\",{\"rel\":\"alternate\",\"hrefLang\":\"en-US\",\"href\":\"https://isaacavazquez.com/writing/2025-fantasy-football-draft-strategy\"}],[\"$\",\"meta\",\"17\",{\"name\":\"format-detection\",\"content\":\"telephone=no, address=no, email=no\"}],[\"$\",\"meta\",\"18\",{\"property\":\"og:title\",\"content\":\"Isaac Vazquez – 2025 Fantasy Football Draft Strategy - Data-Driven Approach | Analytics Guide\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:description\",\"content\":\"Dominate your fantasy football draft with advanced analytics and tier-based strategies. Expert insights on data-driven draft approaches for 2025.\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:url\",\"content\":\"https://isaacavazquez.com/writing/2025-fantasy-football-draft-strategy\"}],[\"$\",\"meta\",\"21\",{\"property\":\"og:site_name\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"22\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"23\",{\"property\":\"og:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"meta\",\"24\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"25\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"26\",{\"property\":\"og:image:alt\",\"content\":\"Isaac Vazquez - Technical Product Manager & UC Berkeley Haas MBA Candidate\"}],[\"$\",\"meta\",\"27\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"28\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"29\",{\"name\":\"twitter:site\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"30\",{\"name\":\"twitter:creator\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"31\",{\"name\":\"twitter:title\",\"content\":\"Isaac Vazquez – 2025 Fantasy Football Draft Strategy - Data-Driven Approach | Analytics Guide\"}],[\"$\",\"meta\",\"32\",{\"name\":\"twitter:description\",\"content\":\"Dominate your fantasy football draft with advanced analytics and tier-based strategies. Expert insights on data-driven draft approaches for 2025.\"}],[\"$\",\"meta\",\"33\",{\"name\":\"twitter:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"link\",\"34\",{\"rel\":\"icon\",\"href\":\"/favicon.png\"}],[\"$\",\"$L5\",\"35\",{}]]}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}],\"loading\":null,\"isPartial\":false}\n"}}