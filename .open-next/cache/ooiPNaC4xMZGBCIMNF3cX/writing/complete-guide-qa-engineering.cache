isPartial\":false}\n","/_head":"1:\"$Sreact.fragment\"\n2:I[484,[],\"ViewportBoundary\"]\n3:I[484,[],\"MetadataBoundary\"]\n4:\"$Sreact.suspense\"\n9:I[6869,[],\"IconMark\"]\n0:{\"buildId\":\"ooiPNaC4xMZGBCIMNF3cX\",\"rsc\":[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L2\",null,{\"children\":[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L3\",null,{\"children\":[\"$\",\"$4\",null,{\"name\":\"Next.Metadata\",\"children\":[[\"$\",\"title\",\"0\",{\"children\":\"Isaac Vazquez – Product Manager | UC Berkeley Haas MBA | Portfolio & Case Studies | Isaac Vazquez\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Master QA engineering with strategic business insights from Austin civic tech and Silicon Valley innovation. Comprehensive guide covering testing strategies, automation, and quality processes that drive business value.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"author\",\"href\":\"https://isaacavazquez.com\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"4\",{\"name\":\"creator\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"5\",{\"name\":\"publisher\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"7\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"meta\",\"8\",{\"name\":\"expertise\",\"content\":\"QA engineering, software testing, quality assurance, test automation, Austin QA engineer, Bay Area QA, business strategy QA, product management testing, UC Berkeley MBA QA, strategic testing practices\"}],[\"$\",\"meta\",\"9\",{\"name\":\"profession\",\"content\":\"Technical Product Manager\"}],[\"$\",\"meta\",\"10\",{\"name\":\"content-type\",\"content\":\"Article\"}],[\"$\",\"meta\",\"11\",{\"name\":\"summary\",\"content\":\"Master QA engineering with strategic business insights from Austin civic tech and Silicon Valley innovation. Comprehensive guide covering testing strategies, automation, and quality processes that drive business value.\"}],[\"$\",\"meta\",\"12\",{\"name\":\"article:published_time\",\"content\":\"2025-01-24\"}],[\"$\",\"meta\",\"13\",{\"name\":\"article:modified_time\",\"content\":\"2025-01-24\"}],[\"$\",\"meta\",\"14\",{\"name\":\"og:updated_time\",\"content\":\"2025-01-24\"}],[\"$\",\"link\",\"15\",{\"rel\":\"canonical\",\"href\":\"https://isaacavazquez.com/writing/complete-guide-qa-engineering\"}],[\"$\",\"link\",\"16\",{\"rel\":\"alternate\",\"hrefLang\":\"en-US\",\"href\":\"https://isaacavazquez.com/writing/complete-guide-qa-engineering\"}],[\"$\",\"meta\",\"17\",{\"name\":\"format-detection\",\"content\":\"telephone=no, address=no, email=no\"}],[\"$\",\"meta\",\"18\",{\"property\":\"og:title\",\"content\":\"Isaac Vazquez – Complete Guide to QA Engineering - Business Strategy & Testing Best Practices | Isaac Vazquez\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:description\",\"content\":\"Master QA engineering with strategic business insights from Austin civic tech and Silicon Valley innovation. Comprehensive guide covering testing strategies, automation, and quality processes that drive business value.\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:url\",\"content\":\"https://isaacavazquez.com/writing/complete-guide-qa-engineering\"}],[\"$\",\"meta\",\"21\",{\"property\":\"og:site_name\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"22\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"23\",{\"property\":\"og:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"meta\",\"24\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"25\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"26\",{\"property\":\"og:image:alt\",\"content\":\"Isaac Vazquez - Technical Product Manager & UC Berkeley Haas MBA Candidate\"}],[\"$\",\"meta\",\"27\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"28\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"29\",{\"name\":\"twitter:site\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"30\",{\"name\":\"twitter:creator\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"31\",{\"name\":\"twitter:title\",\"content\":\"Isaac Vazquez – Complete Guide to QA Engineering - Business Strategy & Testing Best Practices | Isaac Vazquez\"}],[\"$\",\"meta\",\"32\",{\"name\":\"twitter:description\",\"content\":\"Master QA engineering with strategic business insights from Austin civic tech and Silicon Valley innovation. Comprehensive guide covering testing strategies, automation, and quality processes that drive business value.\"}],\"$L5\",\"$L6\",\"$L7\"]}]}]}],\"$L8\"]}],\"loading\":null,\"isPartial\":false}\n5:[\"$\",\"meta\",\"33\",{\"name\":\"twitter:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}]\n6:[\"$\",\"link\",\"34\",{\"rel\":\"icon\",\"href\":\"/favicon.png\"}]\n7:[\"$\",\"$L9\",\"35\",{}]\n8:[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]\n"}}