content\\\":\\\"630\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"26\\\",{\\\"property\\\":\\\"og:image:alt\\\",\\\"content\\\":\\\"Isaac Vazquez - Technical Product Manager \\u0026 UC Berkeley Haas MBA Candidate\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"27\\\",{\\\"property\\\":\\\"og:type\\\",\\\"content\\\":\\\"website\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"28\\\",{\\\"name\\\":\\\"twitter:card\\\",\\\"content\\\":\\\"summary_large_image\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"29\\\",{\\\"name\\\":\\\"twitter:site\\\",\\\"content\\\":\\\"@isaacvazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"30\\\",{\\\"name\\\":\\\"twitter:creator\\\",\\\"content\\\":\\\"@isaacvazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"31\\\",{\\\"name\\\":\\\"twitter:title\\\",\\\"content\\\":\\\"Isaac Vazquez – Building an Investment Research Platform for Faster, Clearer Equity Analysis\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"32\\\",{\\\"name\\\":\\\"twitter:description\\\",\\\"content\\\":\\\"See how I built an investment research workspace that combines curated snapshots, valuation review, and browser-saved portfolio tracking without relying on spreadsheet-heavy workflows.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"33\\\",{\\\"name\\\":\\\"twitter:image\\\",\\\"content\\\":\\\"https://isaacavazquez.com/opengraph-image\\\"}],[\\\"$\\\",\\\"link\\\",\\\"34\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/favicon.png\\\"}],[\\\"$\\\",\\\"$L1a\\\",\\\"35\\\",{}]]\\n\"])</script></body></html>","rsc":"1:\"$Sreact.fragment\"\n2:I[7106,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"Providers\"]\n3:I[4665,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"StaticHeader\"]\n4:I[9644,[\"8500\",\"static/chunks/8500-41fa79ac74