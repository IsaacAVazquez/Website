age\\\":[\\\"https://isaacavazquez.com/og-image.png\\\"],\\\"author\\\":{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Person\\\",\\\"@id\\\":\\\"https://isaacavazquez.com#person\\\",\\\"name\\\":\\\"Isaac Vazquez\\\",\\\"alternateName\\\":\\\"Isaac Vazquez\\\",\\\"description\\\":\\\"Product Manager and UC Berkeley Haas MBA Candidate with 5+ years building SaaS products reaching 60M+ users. Case studies, product thinking, and PM frameworks.\\\",\\\"url\\\":\\\"https://isaacavazquez.com\\\",\\\"image\\\":\\\"https://isaacavazquez.com/opengraph-image\\\",\\\"sameAs\\\":[\\\"https://linkedin.com/in/isaac-vazquez\\\",\\\"https://github.com/IsaacAVazquez\\\"],\\\"jobTitle\\\":\\\"Technical Product Manager \\u0026 UC Berkeley MBA Candidate\\\"},\\\"articleSection\\\":\\\"Investment Research\\\",\\\"wordCount\\\":1132,\\\"keywords\\\":\\\"investment research platform, fintech product design, equity analysis workflow, portfolio tracking app, valuation dashboard, investment research tools\\\"}\"])</script><script>self.__next_f.push([1,\"8:[[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"@id\\\\\\\":\\\\\\\"https://isaacavazquez.com#breadcrumb\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://isaacavazquez.com/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Writing\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://isaacavazquez.com/writing\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"Building an Investment Research Platform That Prefers Clarity Over Spreadsheet Sprawl\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://isaacavazquez.com/writing/building-an-investment-research-platform\\\\\\\"}]}\\\"},\\\"suppressHydrationWarning\\\":true}],[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$11\\\"},\\\"suppressHydrationWarning\\\":true}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"min-h-screen py-16 sm:py-20 px-4 sm:px-6 lg:px-8\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"max-w-4xl mx-auto\\\",\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"mb-12\\\",\\\"children\\\":[[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4\\\",\\\"children\\\":\\\"Building an Investment Research Platform That Prefers Clarity Over Spreadsheet Sprawl\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-4 text-neutral-600 dark:text-neutral-400 mb-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"time\\\",null,{\\\"dateTime\\\":\\\"2026-04-02\\\",\\\"children\\\":\\\"April 1, 2026\\\"}],[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"•\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"6 min read\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"•\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":[1132,\\\" words\\\"]}]]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2 mb-8\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",\\\"Investment Research\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Investment Research\\\"}],[\\\"$\\\",\\\"span\\\",\\\"Fintech Product\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Fintech Product\\\"}],[\\\"$\\\",\\\"span\\\",\\\"Portfolio Tracking\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Portfolio Tracking\\\"}],\\\"$L12\\\",\\\"$L13\\\",\\\"$L14\\\",\\\"$L15\\\"]}]]}],\\\"$L16\\\",\\\"$L17\\\"]}]}]]\\n\"])</script><script>self.__next_f.push([1,\"19:I[9148,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"2159\\\",\\\"static/chunks/2159-a2185eb42de1551d.js\\\",\\\"8437\\\",\\\"static/chunks/8437-f676cf471bf9d370.js\\\",\\\"5851\\\",\\\"static/chunks/app/writing/%5Bslug%5D/page-7adc4d02f86dad9e.js\\\"],\\\"AuthorBio\\\"]\\n12:[\\\"$\\\",\\\"span\\\",\\\"Equity Analysis\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Equity Analysis\\\"}]\\n13:[\\\"$\\\",\\\"span\\\",\\\"Financial Data\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Financial Data\\\"}]\\n14:[\\\"$\\\",\\\"span\\\",\\\"Next.js\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Next.js\\\"}]\\n15:[\\\"$\\\",\\\"span\\\",\\\"Product Design\\\",{\\\"className\\\":\\\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\\\",\\\"children\\\":\\\"Product Design\\\"}]\\n18:T1e6e,\"])</script><script>self.__next_f.push([1,\"\\u003ch1\\u003eBuilding an Investment Research Platform That Prefers Clarity Over Spreadsheet Sprawl\\u003c/h1\\u003e\\n\\u003cp\\u003eIf you want to see the product before reading the breakdown, open the \\u003ca href=\\\"/investments\\\"\\u003eInvestment Research Platform\\u003c/a\\u003e.\\u003c/p\\u003e\\n\\u003cp\\u003eMost personal investing workflows break down in the same place: the analysis is scattered. Price charts live in one tab, financial statements in another, notes in a spreadsheet, and portfolio tracking in a tool that has no idea why you bought the stock in the first place.\\u003c/p\\u003e\\n\\u003cp\\u003eI built this project because I wanted a research workflow that felt more like a decision workspace than a collection of disconnected utilities. The goal was not to recreate a full institutional terminal. The goal was to make the most important parts of equity research easier to review, compare, and revisit without adding more friction.\\u003c/p\\u003e\\n\\u003ch2\\u003eThe Problem This Product Tries To Solve\\u003c/h2\\u003e\\n\\u003cp\\u003eRetail research tools often force a tradeoff between breadth and clarity.\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eBroad platforms surface a huge number of metrics, but they bury the signal under dense tables and too many navigation layers.\\u003c/li\\u003e\\n\\u003cli\\u003eSimpler trackers make portfolio monitoring easy, but they stop short of helping you understand the business behind the position.\\u003c/li\\u003e\\n\\u003cli\\u003eSpreadsheet-based workflows are flexible, but they are tedious to maintain and hard to keep consistent over time.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003cp\\u003eThat combination creates a quiet failure mode: you can gather plenty of information without actually improving the decision.\\u003c/p\\u003e\\n\\u003cp\\u003eI wanted a workspace that answered three practical questions quickly:\\u003c/p\\u003e\\n\\u003col\\u003e\\n\\u003cli\\u003eWhat does this company look like right now?\\u003c/li\\u003e\\n\\u003cli\\u003eHow does the valuation compare with the operating profile?\\u003c/li\\u003e\\n\\u003cli\\u003eWhat does this mean for the positions I already hold?\\u003c/li\\u003e\\n\\u003c/ol\\u003e\\n\\u003ch2\\u003eWhy The Product Uses Curated Snapshots Instead Of Chasing Infinite Live Data\\u003c/h2\\u003e\\n\\u003cp\\u003eOne of the earliest product decisions was to avoid pretending this needed to be a tick-by-tick trading terminal.\\u003c/p\\u003e\\n\\u003cp\\u003eThe platform is built around curated company snapshots, valuation panels, price history, and financial statement views. That structure matters because the highest-value research questions usually do not require every possible data point in real time. They require trustworthy context with clear fallbacks.\\u003c/p\\u003e\\n\\u003cp\\u003eThat is why the product leans on a curated symbol set and snapshot-backed research rather than an unlimited search surface. It narrows the scope enough to keep the experience reliable while still giving the user a strong research loop.\\u003c/p\\u003e\\n\\u003cp\\u003eThis tradeoff improves the product in a few ways:\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eThe research experience is more stable because every symbol can be shaped into the same interface.\\u003c/li\\u003e\\n\\u003cli\\u003eThe UI can emphasize interpretation instead of raw data dumping.\\u003c/li\\u003e\\n\\u003cli\\u003eThe system can degrade more gracefully when a data source is incomplete.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003cp\\u003eIn other words, curation is not a limitation here. It is part of the product strategy.\\u003c/p\\u003e\\n\\u003ch2\\u003eThe Core Product Decisions\\u003c/h2\\u003e\\n\\u003ch3\\u003e1. Research And Portfolio Tracking Live In The Same Workspace\\u003c/h3\\u003e\\n\\u003cp\\u003eThe route is organized around two tabs: research and portfolio. That sounds simple, but it changes the product meaningfully.\\u003c/p\\u003e\\n\\u003cp\\u003eInstead of treating research as a separate activity from portfolio management, the platform lets both workflows share the same mental model. You can move from a holding to a deeper review of the underlying company without changing tools or losing context.\\u003c/p\\u003e\\n\\u003cp\\u003eThat matters because investing decisions are rarely isolated. The useful question is not just \\\"Is this stock interesting?\\\" It is \\\"Is this stock interesting relative to what I already own?\\\"\\u003c/p\\u003e\\n\\u003ch3\\u003e2. Browser-Saved Portfolio State Beats Heavy Account Setup For This Use Case\\u003c/h3\\u003e\\n\\u003cp\\u003eI chose browser-local persistence for portfolio tracking instead of building a full account system.\\u003c/p\\u003e\\n\\u003cp\\u003eFor this project, that was the right call. The value of the portfolio tab is fast iteration, not multi-user infrastructure. Local persistence keeps the workflow immediate and private, removes sign-in friction, and lets the product behave more like a personal research notebook than a brokerage dashboard.\\u003c/p\\u003e\\n\\u003cp\\u003eThis is a good example of scope discipline. Adding authentication would have made the product feel more complete on paper, but it would not have made the core research loop materially better.\\u003c/p\\u003e\\n\\u003ch3\\u003e3. Valuation Needs Context, Not Just Ratios\\u003c/h3\\u003e\\n\\u003cp\\u003eA ratio by itself rarely helps. A low multiple can signal value, but it can also reflect deteriorating fundamentals. A premium multiple may be justified if growth, margins, and balance-sheet quality support it.\\u003c/p\\u003e\\n\\u003cp\\u003eThat is why the experience is organized around adjacent panels instead of isolated numbers. The user can move across valuation, growth, profitability, financial statements, industry context, and price history without reorienting every time.\\u003c/p\\u003e\\n\\u003cp\\u003eThe product design principle here is simple: if a metric invites interpretation, the supporting context should be close by.\\u003c/p\\u003e\\n\\u003ch2\\u003eHow The Experience Works\\u003c/h2\\u003e\\n\\u003cp\\u003eAt a high level, the platform behaves like a structured research desk:\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eA research view surfaces company snapshots, valuation context, statement data, and supporting panels.\\u003c/li\\u003e\\n\\u003cli\\u003eA portfolio view tracks holdings and portfolio-level state in the browser.\\u003c/li\\u003e\\n\\u003cli\\u003eRoute state allows specific symbols and sections to be linked directly, which makes the interface easier to revisit with intent.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003cp\\u003eThe implementation choice underneath that experience is just as important as the interface: stable snapshots instead of fragile ad hoc queries everywhere.\\u003c/p\\u003e\\n\\u003cp\\u003eThat allows the product to focus on what users actually need from a public research tool:\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003efast page loads\\u003c/li\\u003e\\n\\u003cli\\u003econsistent panel structure\\u003c/li\\u003e\\n\\u003cli\\u003eunderstandable coverage boundaries\\u003c/li\\u003e\\n\\u003cli\\u003efewer moments where the UI looks \\\"live\\\" but the data is incomplete\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch2\\u003eTradeoffs I Would Make Again\\u003c/h2\\u003e\\n\\u003ch3\\u003eReliable Fallbacks Over Endless Coverage\\u003c/h3\\u003e\\n\\u003cp\\u003eA smaller but cleaner research universe is better than a giant index with uneven quality.\\u003c/p\\u003e\\n\\u003ch3\\u003eWorkspace Framing Over Feature Creep\\u003c/h3\\u003e\\n\\u003cp\\u003eThe product is intentionally framed as a workspace, not a brokerage clone. That keeps the experience centered on research and portfolio understanding instead of trying to imitate execution platforms.\\u003c/p\\u003e\\n\\u003ch3\\u003eDecision Support Over Quant Theater\\u003c/h3\\u003e\\n\\u003cp\\u003eThere are plenty of finance products that use metric density as a stand-in for usefulness. I would rather show fewer things, arranged with more intent, than turn the page into a wall of numbers that looks impressive but slows down judgment.\\u003c/p\\u003e\\n\\u003ch2\\u003eWhat This Project Taught Me\\u003c/h2\\u003e\\n\\u003cp\\u003eBuilding finance products is often an exercise in restraint.\\u003c/p\\u003e\\n\\u003cp\\u003eThe temptation is to add more coverage, more models, more feeds, more views, and more technical sophistication. But most of the user value comes from making it easier to move from raw information to a coherent point of view.\\u003c/p\\u003e\\n\\u003cp\\u003eThis project reinforced a product lesson I trust across domains: good tools reduce decision fatigue before they add decision power.\\u003c/p\\u003e\\n\\u003cp\\u003eFor research products specifically, that means:\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003edefine the workflow before expanding the dataset\\u003c/li\\u003e\\n\\u003cli\\u003etreat fallback behavior as a first-class feature\\u003c/li\\u003e\\n\\u003cli\\u003ekeep the interface close to the real questions investors are asking\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch2\\u003eTry The Live Product\\u003c/h2\\u003e\\n\\u003cp\\u003eYou can explore the full product at \\u003ca href=\\\"/investments\\\"\\u003eInvestment Research Platform\\u003c/a\\u003e.\\u003c/p\\u003e\\n\\u003cp\\u003eIf you open it, the quickest way to understand the experience is to move between the research and portfolio views and notice how the product keeps analysis and position management in the same frame. That integration is the point of the project.\\u003c/p\\u003e\\n\"])</script><script>self.__next_f.push([1,\"16:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose prose-neutral dark:prose-invert max-w-none mb-12\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$18\\\"}}]\\n17:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-16 mb-12\\\",\\\"children\\\":[\\\"$\\\",\\\"$L19\\\",null,{\\\"variant\\\":\\\"full\\\"}]}]\\n\"])</script><script>self.__next_f.push([1,\"d:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1\\\"}]]\\n\"])</script><script>self.__next_f.push([1,\"1a:I[6869,[],\\\"IconMark\\\"]\\nb:null\\n\"])</script><script>self.__next_f.push([1,\"f:[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Isaac Vazquez – Product Manager | UC Berkeley Haas MBA | Portfolio \\u0026 Case Studies | Isaac Vazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"See how I built an investment research workspace that combines curated snapshots, valuation review, and browser-saved portfolio tracking without relying on spreadsheet-heavy workflows.\\\"}],[\\\"$\\\",\\\"link\\\",\\\"2\\\",{\\\"rel\\\":\\\"author\\\",\\\"href\\\":\\\"https://isaacavazquez.com\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"3\\\",{\\\"name\\\":\\\"author\\\",\\\"content\\\":\\\"Isaac Vazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"4\\\",{\\\"name\\\":\\\"creator\\\",\\\"content\\\":\\\"Isaac Vazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"5\\\",{\\\"name\\\":\\\"publisher\\\",\\\"content\\\":\\\"Isaac Vazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"6\\\",{\\\"name\\\":\\\"robots\\\",\\\"content\\\":\\\"index, follow\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"7\\\",{\\\"name\\\":\\\"googlebot\\\",\\\"content\\\":\\\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"8\\\",{\\\"name\\\":\\\"expertise\\\",\\\"content\\\":\\\"investment research platform, fintech product design, equity analysis workflow, portfolio tracking app, valuation dashboard, investment research tools\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"9\\\",{\\\"name\\\":\\\"profession\\\",\\\"content\\\":\\\"Technical Product Manager\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"10\\\",{\\\"name\\\":\\\"content-type\\\",\\\"content\\\":\\\"Article\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"11\\\",{\\\"name\\\":\\\"summary\\\",\\\"content\\\":\\\"See how I built an investment research workspace that combines curated snapshots, valuation review, and browser-saved portfolio tracking without relying on spreadsheet-heavy workflows.\\\"}],[\\\"$\\\",\\\"meta\\\",\