public rankings, scoring toggles, freshness timestamps, and the draft assistant aligned around the same published snapshot data.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"33\\\",{\\\"name\\\":\\\"twitter:image\\\",\\\"content\\\":\\\"https://isaacavazquez.com/opengraph-image\\\"}],[\\\"$\\\",\\\"link\\\",\\\"34\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/favicon.png\\\"}],[\\\"$\\\",\\\"$L1a\\\",\\\"35\\\",{}]]\\n\"])</script></body></html>","rsc":"1:\"$Sreact.fragment\"\n2:I[7106,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"Providers\"]\n3:I[4665,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"StaticHeader\"]\n4:I[9644,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"ConditionalLayout\"]\n5:I[7121,[],\"\"]\n6:I[4581,[],\"\"]\n7:I[3693,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"2159\",\"static/chunks/2159-a2185eb42de1551d.js\",\"4345\",\"static/chunks/app/not-found-db6358576148c4d6.js\"],\"default\"]\n9:I[484,[],\"OutletBoundary\"]\na:\"$Sreact.suspense\"\nc:I[484,[],\"ViewportBoundary\"]\ne:I[484,[],\"MetadataBoundary\"]\n10:I[7123,[],\"\"]\n:HL[\"/_next/static/media/bb3ef058b751a6ad-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/css/15ee1b5f957de41a.css\",\"style\"]\n:HL[\"/_next/static/css/51be877e094ecfa4.css\",\"style\"]\n0:{\"P\":null,\"b\":\"ooiPNaC4xMZGBCIMNF3cX\",\"c\":[\"\",\"writing\",\"building-a-fantasy-football-rankings-platform\"],\"q\":\"\",\"i\":false,\"f\":[[[\"\",{\"children\":[\"writing\",{\"children\":[[\"slug\",\"building-a-fantasy-football-rankings-platform\",\"d\"],{\"children\":[\"__PAGE__\",{}]}]}]},\"$undefined\",\"$undefined\",true],[[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/css/15ee1b5f957de41a.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}],[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/css/51be877e094ecfa4.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]],[\"$\",\"html\",null,{\"lang\":\"en\",\"className\":\"scroll-smooth\",\"suppressHydrationWarning\":true,\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"meta\",null,{\"name\":\"theme-color\",\"content\":\"#2563EB\"}],[\"$\",\"meta\",null,{\"name\":\"color-scheme\",\"content\":\"light dark\"}],[\"$\",\"meta\",null,{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1, viewport-fit=cover\"}],[\"$\",\"meta\",null,{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",null,{\"name\":\"apple-mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",null,{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"default\"}],[\"$\",\"meta\",null,{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",null,{\"name\":\"application-name\",\"content\":\"Isaac Vazquez Portfolio\"}],[\"$\",\"meta\",null,{\"name\":\"format-detection\",\"content\":\"telephone=no, date=no, email=no, address=no\"}],[\"$\",\"meta\",null,{\"name\":\"msapplication-TileColor\",\"content\":\"#2563EB\"}],[\"$\",\"meta\",null,{\"name\":\"msapplication-config\",\"content\":\"/browserconfig.xml\"}],[\"$\",\"link\",null,{\"rel\":\"manifest\",\"href\":\"/manifest.json\"}],[\"$\",\"link\",null,{\"rel\":\"apple-touch-icon\",\"sizes\":\"152x152\",\"href\":\"/icons/icon-152x152.png\"}],[\"$\",\"link\",null,{\"rel\":\"icon\",\"type\":\"image/png\",\"sizes\":\"96x96\",\"href\":\"/icons/icon-96x96.png\"}],[\"$\",\"link\",null,{\"rel\":\"icon\",\"type\":\"image/png\",\"sizes\":\"72x72\",\"href\":\"/icons/icon-72x72.png\"}],[\"$\",\"link\",null,{\"rel\":\"alternate\",\"type\":\"application/rss+xml\",\"title\":\"Isaac Vazquez - Writing & Insights\",\"href\":\"/api/rss\"}]]}],[\"$\",\"body\",null,{\"className\":\"__variable_f367f3 __variable_3c557b font-sans min-h-screen antialiased\",\"children\":[\"$\",\"$L2\",null,{\"children\":[[\"$\",\"a\",null,{\"href\":\"#main-content\",\"className\":\"sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[var(--neutral-900)] focus:text-white focus:rounded-lg focus:shadow-lg\",\"children\":\"Skip to main content\"}],[\"$\",\"$L3\",null,{}],[\"$\",\"$L4\",null,{\"children\":[\"$\",\"$L5\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L6\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":[[\"$\",\"$L7\",null,{}],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]]}]}]]}]]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L5\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L6\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L5\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L6\",null,{}],\"templateStyles\":\"$undefined\",\"templ