,[\"$\",\"meta\",\"10\",{\"name\":\"content-type\",\"content\":\"Article\"}],[\"$\",\"meta\",\"11\",{\"name\":\"summary\",\"content\":\"Dominate your fantasy football waiver wire with data-driven strategies. Learn to identify breakout candidates and sustainable value using advanced analytics.\"}],[\"$\",\"meta\",\"12\",{\"name\":\"article:published_time\",\"content\":\"2025-01-24\"}],[\"$\",\"meta\",\"13\",{\"name\":\"article:modified_time\",\"content\":\"2025-01-24\"}],[\"$\",\"meta\",\"14\",{\"name\":\"og:updated_time\",\"content\":\"2025-01-24\"}],[\"$\",\"link\",\"15\",{\"rel\":\"canonical\",\"href\":\"https://isaacavazquez.com/writing/waiver-wire-mastery-hidden-gems\"}],[\"$\",\"link\",\"16\",{\"rel\":\"alternate\",\"hrefLang\":\"en-US\",\"href\":\"https://isaacavazquez.com/writing/waiver-wire-mastery-hidden-gems\"}],[\"$\",\"meta\",\"17\",{\"name\":\"format-detection\",\"content\":\"telephone=no, address=no, email=no\"}],[\"$\",\"meta\",\"18\",{\"property\":\"og:title\",\"content\":\"Isaac Vazquez – Fantasy Football Waiver Wire Strategy - Analytics Guide to Finding Hidden Gems\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:description\",\"content\":\"Dominate your fantasy football waiver wire with data-driven strategies. Learn to identify breakout candidates and sustainable value using advanced analytics.\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:url\",\"content\":\"https://isaacavazquez.com/writing/waiver-wire-mastery-hidden-gems\"}],[\"$\",\"meta\",\"21\",{\"property\":\"og:site_name\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"22\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"23\",{\"property\":\"og:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"meta\",\"24\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"25\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"26\",{\"property\":\"og:image:alt\",\"content\":\"Isaac Vazquez - Technical Product Manager & UC Berkeley Haas MBA Candidate\"}],[\"$\",\"meta\",\"27\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"28\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"29\",{\"name\":\"twitter:site\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"30\",{\"name\":\"twitter:creator\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"31\",{\"name\":\"twitter:title\",\"content\":\"Isaac Vazquez – Fantasy Football Waiver Wire Strategy - Analytics Guide to Finding Hidden Gems\"}],[\"$\",\"meta\",\"32\",{\"name\":\"twitter:description\",\"content\":\"Dominate your fantasy football waiver wire with data-driven strategies. Learn to identify breakout candidates and sustainable value using advanced analytics.\"}],[\"$\",\"meta\",\"33\",{\"name\":\"twitter:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"link\",\"34\",{\"rel\":\"icon\",\"href\":\"/favicon.png\"}],[\"$\",\"$L5\",\"35\",{}]]}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}],\"loading\":null,\"isPartial\":false}\n"}}