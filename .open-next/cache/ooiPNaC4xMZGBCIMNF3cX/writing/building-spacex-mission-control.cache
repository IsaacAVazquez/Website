ission-control\",\"d\"],{\"children\":[\"__PAGE__\",{}]}]}]},\"$undefined\",\"$undefined\",true],[[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/css/15ee1b5f957de41a.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}],[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/css/51be877e094ecfa4.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]],[\"$\",\"html\",null,{\"lang\":\"en\",\"className\":\"scroll-smooth\",\"suppressHydrationWarning\":true,\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"meta\",null,{\"name\":\"theme-color\",\"content\":\"#2563EB\"}],[\"$\",\"meta\",null,{\"name\":\"color-scheme\",\"content\":\"light dark\"}],[\"$\",\"meta\",null,{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1, viewport-fit=cover\"}],[\"$\",\"meta\",null,{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",null,{\"name\":\"apple-mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",null,{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"default\"}],[\"$\",\"meta\",null,{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",null,{\"name\":\"application-name\",\"content\":\"Isaac Vazquez Portfolio\"}],[\"$\",\"meta\",null,{\"name\":\"format-detection\",\"content\":\"telephone=no, date=no, email=no, address=no\"}],[\"$\",\"meta\",null,{\"name\":\"msapplication-TileColor\",\"content\":\"#2563EB\"}],[\"$\",\"meta\",null,{\"name\":\"msapplication-config\",\"content\":\"/browserconfig.xml\"}],[\"$\",\"link\",null,{\"rel\":\"manifest\",\"href\":\"/manifest.json\"}],[\"$\",\"link\",null,{\"rel\":\"apple-touch-icon\",\"sizes\":\"152x152\",\"href\":\"/icons/icon-152x152.png\"}],[\"$\",\"link\",null,{\"rel\":\"icon\",\"type\":\"image/png\",\"sizes\":\"96x96\",\"href\":\"/icons/icon-96x96.png\"}],[\"$\",\"link\",null,{\"rel\":\"icon\",\"type\":\"image/png\",\"sizes\":\"72x72\",\"href\":\"/icons/icon-72x72.png\"}],[\"$\",\"link\",null,{\"rel\":\"alternate\",\"type\":\"application/rss+xml\",\"title\":\"Isaac Vazquez - Writing & Insights\",\"href\":\"/api/rss\"}]]}],[\"$\",\"body\",null,{\"className\":\"__variable_f367f3 __variable_3c557b font-sans min-h-screen antialiased\",\"children\":[\"$\",\"$L2\",null,{\"children\":[[\"$\",\"a\",null,{\"href\":\"#main-content\",\"className\":\"sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[var(--neutral-900)] focus:text-white focus:rounded-lg focus:shadow-lg\",\"children\":\"Skip to main content\"}],[\"$\",\"$L3\",null,{}],[\"$\",\"$L4\",null,{\"children\":[\"$\",\"$L5\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L6\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":[[\"$\",\"$L7\",null,{}],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]]}]}]]}]]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L5\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L6\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L5\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L6\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[\"$L8\",null,[\"$\",\"$L9\",null,{\"children\":[\"$\",\"$a\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@b\"}]}]]}],{},null,false,false]},null,false,false]},null,false,false]},null,false,false],[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$Lc\",null,{\"children\":\"$Ld\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$Le\",null,{\"children\":[\"$\",\"$a\",null,{\"name\":\"Next.Metadata\",\"children\":\"$Lf\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}],false]],\"m\":\"$undefined\",\"G\":[\"$10\",[]],\"S\":true}\n11:T5a2,{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"@id\":\"https://isaacavazquez.com/writing/building-spacex-mission-control#article\",\"headline\":\"Building SpaceX Mission Control: Turning Public Launch Data Into A Productized Mission Board\",\"description\":\"See how I built SpaceX Mission Control, a mission-control-style interface with next-launch focus, deep-linked detail panels, and relationship-aware normalization on top of public SpaceX data.\",\"url\":\"https://isaacavazquez.com/writing/building-spacex-mission-control\",\"datePublished\":\"2026-04-02\",\"dateModified\":\"2026-04-02\",\"inLanguage\":\"en-US\",\"isAccessibleForFree\":true,\"image\":[\"https://isaacavazquez.com/og-image.png\"],\"author\":{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"@id\":\"https://isaacavazquez.com#person\",\"name\":\"Isaac Vazquez\",\"alternateName\":\"Isaac Vazquez\",\"description\":\"Product Manager and UC Berkeley Haas MBA Candidate with 5+ years building SaaS products reaching 60M+ users. Case studies, product thinking, and PM frameworks.\",\"url\":\"https://isaacavazquez.com\",\"image\":\"https://isaacavazquez.com/opengraph-image\",\"sameAs\":[\"https://linkedin.com/in/isaac-vazquez\",\"https://github.com/IsaacAVazquez\"],\"jobTitle\":\"Technical Product Manager & UC Berkeley MBA Candidate\"},\"articleSection\":\"Product Design\",\"wordCount\":941,\"keywords\":\"spacex mission control, launch tracker design, public api dashboard, data product design, relationship-aware api, spacex dashboard\"}8:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"@id\\\":\\\"https://isaacavazquez.com#breadcrumb\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://isaacavazquez.com/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Writing\\\",\\\"item\\\":\\\"https://isaacavazquez.com/writing\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Building SpaceX Mission Control: Turning Public Launch Data Into A Productized Mission Board\\\",\\\"item\\\":\\\"https://isaacavazquez.com/writing/building-spacex-mission-control\\\"}]}\"},\"suppressHydrationWarning\":true}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$11\"},\"suppressHydrationWarning\":true}],[\"$\",\"div\",null,{\"className\":\"min-h-screen py-16 sm:py-20 px-4 sm:px-6 lg:px-8\",\"children\":[\"$\",\"article\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"header\",null,{\"className\":\"mb-12\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4\",\"children\":\"Building SpaceX Mission Control: Turning Public Launch Data Into A Productized Mission Board\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 text-neutral-600 dark:text-neutral-400 mb-6\",\"children\":[[\"$\",\"time\",null,{\"dateTime\":\"2026-04-02\",\"children\":\"April 1, 2026\"}],[[\"$\",\"span\",null,{\"children\":\"•\"}],[\"$\",\"span\",null,{\"children\":\"5 min read\"}],[\"$\",\"span\",null,{\"children\":\"•\"}],[\"$\",\"span\",null,{\"children\":[941,\" words\"]}]]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 mb-8\",\"children\":[[\"$\",\"span\",\"Product Design\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"Product Design\"}],[\"$\",\"span\",\"Dashboard Design\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"Dashboard Design\"}],[\"$\",\"span\",\"SpaceX\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"SpaceX\"}],\"$L12\",\"$L13\",\"$L14\",\"$L15\"]}]]}],\"$L16\",\"$L17\"]}]}]]\n19:I[9148,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"2159\",\"static/chunks/2159-a2185eb42de1551d.js\",\"8437\",\"static/chunks/8437-f676cf471bf9d370.js\",\"5851\",\"static/chunks/app/writing/%5Bslug%5D/page-7adc4d02f86dad9e.js\"],\"AuthorBio\"]\n12:[\"$\",\"span\",\"API Design\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"API Design\"}]\n13:[\"$\",\"span\",\"Data Product\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"Data Product\"}]\n14:[\"$\",\"span\",\"Next.js\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"Next.js\"}]\n15:[\"$\",\"span\",\"User Experience\",{\"className\":\"px-3 py-1 text-sm font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-full\",\"children\":\"User Experience\"}]\n18:T18d5,<h1>Building SpaceX Mission Control: Turning Public Launch Data Into A Productized Mission Board</h1>\n<p>If you want to try the product before reading the breakdown, open <a href=\"/spacex-mission-control\">SpaceX Mission Control</a>.</p>\n<p>Public APIs make it easy to access data. They do not automatically make that data feel usable.</p>\n<p>That gap is what this project explores. I wanted to turn public SpaceX launch data into something that felt closer to an operational board than a generic API demo. The result is a mission-control-style product with a clear next-launch focus, a browsable launch board, and deep-linked detail panels that stay aware of the relationships between launches, rockets, payloads, capsules, crew, and launch pads.</p>\n<h2>The Problem With Most Public-Data Demos</h2>\n<p>A lot of public API projects stop at retrieval.</p>\n<ul>\n<li>fetch a list</li>\n<li>render a few cards</li>\n<li>add filters</li>\n<li>call it done</li>\n</ul>\n<p>That proves the integration works, but it does not prove the product works.</p>\n<p>For a subject like spaceflight, the data is inherently relational. A launch means more when you can connect it to the rocket, the orbit, the payloads, the pad, the crew, and the status of the mission itself. A flat list hides most of that richness.</p>\n<p>So the real product question became: how do you make public launch data feel navigable, operational, and worth exploring?</p>\n<h2>Why The Experience Starts With The Next Launch</h2>\n<p>The first major decision was to center the interface on the next launch rather than treat all launches as equal.</p>\n<p>That mirrors how people naturally approach this category. Most users do not arrive asking for an abstract database browse. They want to know what is happening next, when it happens, and why it matters.</p>\n<p>By giving the next launch a dedicated hero treatment, the product establishes a useful hierarchy:</p>\n<ul>\n<li>immediate mission awareness first</li>\n<li>broader board browsing second</li>\n<li>deep detail exploration third</li>\n</ul>\n<p>This is a product-design decision, not just a layout decision. It tells the user where to start.</p>\n<h2>The Core Product Decisions</h2>\n<h3>1. Turn Lists Into A Mission Board</h3>\n<p>The launch board is designed to feel like a working surface, not a passive archive. Upcoming and past launches can be filtered, scanned, and compared in a format that emphasizes operational status rather than generic content cards.</p>\n<p>That choice matters because launch data is inherently event-driven. A board structure makes the timeline and the state changes easier to grasp than a standard blog-style list.</p>\n<h3>2. Make Detail Panels Deep-Linkable</h3>\n<p>One of the most important interaction decisions in the project is that mission detail is deep-linkable through route state.</p>\n<p>That means a specific launch and panel can be shared or revisited directly instead of existing only as transient UI state. It makes the experience more useful for exploration because the user can hold onto a meaningful point inside the product.</p>\n<p>Deep linking is often undervalued in dashboard-style projects. Here it matters because the detail panel is where the relationships between entities become legible.</p>\n<h3>3. Normalize Relationships Instead Of Dumping Raw API Shape Into The UI</h3>\n<p>The most important technical choice underneath the product is relationship-aware normalization.</p>\n<p>The UI should not make users think in raw API fragments. It should present a mission as a connected object:</p>\n<ul>\n<li>what rocket is involved</li>\n<li>which payloads are attached</li>\n<li>whether crew or capsules matter</li>\n<li>where the mission launches</li>\n<li>how the mission fits into a larger launch story</li>\n</ul>\n<p>That translation layer is what turns \"API integration\" into product behavior.</p>\n<h2>How The Experience Works</h2>\n<p>At a high level, the product has three layers:</p>\n<h3>Mission Awareness</h3>\n<p>The hero surface highlights the next launch and frames it as the primary live event.</p>\n<h3>Board Browsing</h3>\n<p>The launch board supports scanning upcoming and past missions in a more operational format.</p>\n<h3>Contextual Detail</h3>\n<p>The detail rail lets the user dive into the selected mission with relationship-aware context that would be awkward to understand from a flat feed.</p>\n<p>The client also refreshes live data on an interval, which helps the product feel active without forcing the user to manually reload in order to stay oriented.</p>\n<h2>Why This Needed To Feel Like A Product, Not A Showcase</h2>\n<p>Space-themed UI can become gimmicky very fast. I wanted this project to avoid that trap.</p>\n<p>The goal was not to make something that simply looked cinematic. The goal was to create a productized data experience where the interface hierarchy, the route state, and the data normalization all support a clearer understanding of the missions.</p>\n<p>That required restraint:</p>\n<ul>\n<li>use visual atmosphere without sacrificing legibility</li>\n<li>let the mission data drive the interaction model</li>\n<li>keep the detail layer useful, not decorative</li>\n</ul>\n<p>That balance is what makes the project interesting to me. The style is part of the experience, but it is not the product by itself.</p>\n<h2>What This Project Taught Me</h2>\n<p>Data products get stronger when they acknowledge the shape of the domain instead of forcing the domain into generic UI patterns.</p>\n<p>Spaceflight is event-driven, relationship-heavy, and status-sensitive. Once I treated those qualities as design inputs, the product got better quickly. The next-launch hero, the mission board, and the deep-linked detail panel all came out of respecting that structure.</p>\n<p>This project also reinforced something I care about in dashboard design: route state is part of usability. A view you can return to and share is more valuable than one that only exists in the current browser moment.</p>\n<h2>Try The Live Product</h2>\n<p>You can explore the full experience at <a href=\"/spacex-mission-control\">SpaceX Mission Control</a>.</p>\n<p>The best way to understand the product is to start with the next-launch hero, switch between upcoming and past launches, and then open a mission detail panel to see how the product turns separate API entities into one coherent mission view.</p>\n16:[\"$\",\"div\",null,{\"className\":\"prose prose-neutral dark:prose-invert max-w-none mb-12\",\"dangerouslySetInnerHTML\":{\"__html\":\"$18\"}}]\n17:[\"$\",\"div\",null,{\"className\":\"mt-16 mb-12\",\"children\":[\"$\",\"$L19\",null,{\"variant\":\"full\"}]}]\nd:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n1a:I[6869,[],\"IconMark\"]\nb:null\nf:[[\"$\",\"title\",\"0\",{\"children\":\"Isaac Vazquez – Product Manager | UC Berkeley Haas MBA | Portfolio & Case Studies | Isaac Vazquez\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"See how I built SpaceX Mission Control, a mission-control-style interface with next-launch focus, deep-linked detail panels, and relationship-aware normalization on top of public SpaceX data.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"author\",\"href\":\"https://isaacavazquez.com\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"4\",{\"name\":\"creator\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"5\",{\"name\":\"publisher\",\"content\":\"Isaac Vazquez\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"7\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"meta\",\"8\",{\"name\":\"expertise\",\"content\":\"spacex mission control, launch tracker design, public api dashboard, data product design, relationship-aware api, spacex dashboard\"}],[\"$\",\"meta\",\"9\",{\"name\":\"profession\",\"content\":\"Technical Product Manager\"}],[\"$\",\"meta\",\"10\",{\"name\":\"content-type\",\"content\":\"Article\"}],[\"$\",\"meta\",\"11\",{\"name\":\"summary\",\"content\":\"See how I built SpaceX Mi