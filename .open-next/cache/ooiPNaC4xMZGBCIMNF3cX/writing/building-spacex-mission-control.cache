0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z\"></path><path d=\"M8 11l0 5\"></path><path d=\"M8 8l0 .01\"></path><path d=\"M12 16l0 -5\"></path><path d=\"M16 16v-3a2 2 0 0 0 -4 0\"></path></svg></a><a href=\"https://github.com/IsaacAVazquez\" aria-label=\"Visit Isaac Vazquez&#x27;s GitHub profile\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border transition-colors border-[var(--border-primary)] text-[var(--text-tertiary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" width=\"18\" height=\"18\" aria-hidden=\"true\"><path d=\"M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5\"></path></svg></a></nav><div class=\"flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--text-tertiary)]\"><span>2026</span><a class=\"transition-colors hover:text-[var(--text-primary)]\" href=\"/accessibility\">Accessibility</a><a href=\"https://isaacavazquez.com\" class=\"font-medium transition-colors text-[var(--text-primary)] hover:text-[var(--color-primary)]\">isaacavazquez.com</a></div></div></div></div></footer><script src=\"/_next/static/chunks/webpack-dd523bc6d663ffa9.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7106,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"5856\\\",\\\"static/chunks/5856-817fbea2f02f29bd.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-be1124ffefb0122c.js\\\"],\\\"Providers\\\"]\\n3:I[4665,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"5856\\\",\\\"static/chunks/5856-817fbea2f02f29bd.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-be1124ffefb0122c.js\\\"],\\\"StaticHeader\\\"]\\n4:I[9644,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"5856\\\",\\\"static/chunks/5856-817fbea2f02f29bd.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-be1124ffefb0122c.js\\\"],\\\"ConditionalLayout\\\"]\\n5:I[7121,[],\\\"\\\"]\\n6:I[4581,[],\\\"\\\"]\\n7:I[3693,[\\\"8500\\\",\\\"static/chunks/8500-41fa79ac743d83f1.js\\\",\\\"8409\\\",\\\"static/chunks/8409-baa9df2477416543.js\\\",\\\"2159\\\",\\\"static/chunks/2159-a2185eb42de1551d.js\\\",\\\"4345\\\",\\\"static/chunks/app/not-found-db6358576148c4d6.js\\\"],\\\"default\\\"]\\n9:I[484,[],\\\"OutletBoundary\\\"]\\na:\\\"$Sreact.suspense\\\"\\nc:I[484,[],\\\"ViewportBoundary\\\"]\\ne:I[484,[],\\\"MetadataBoundary\\\"]\\n10:I[7123,[],\\\"\\\"]\\n:HL[\\\"/_next/static/media/bb3ef058b751a6ad-s.p.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/css/15ee1b5f957de41a.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/css/51be877e094ecfa4.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"b\\\":\\\"ooiPNaC4xMZGBCIMNF3cX\\\",\\\"c\\\":[\\\"\\\",\\\"writing\\\",\\\"building-spacex-mission-control\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"writing\\\",{\\\"children\\\":[[\\\"slug\\\",\\\"building-spacex-mission-control\\\",\\\"d\\\"],{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]}]},\\\"$undefined\\\",\\\"$undefined\\\",true],[[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[[[\\\"$\\\",\\\"link\\\",\\\"0\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/css/15ee1b5f957de41a.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"link\\\",\\\"1\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/css/51be877e094ecfa4.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}]],[\\\"$\\\",\\\"html\\\",null,{\\\"lang\\\":\\\"en\\\",\\\"className\\\":\\\"scroll-smooth\\\",\\\"suppressHydrationWarning\\\":true,\\\"children\\\":[[\\\"$\\\",\\\"head\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"theme-color\\\",\\\"content\\\":\\\"#2563EB\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"color-scheme\\\",\\\"content\\\":\\\"light dark\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1, viewport-fit=cover\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"mobile-web-app-capable\\\",\\\"content\\\":\\\"yes\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"apple-mobile-web-app-capable\\\",\\\"content\\\":\\\"yes\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"apple-mobile-web-app-status-bar-style\\\",\\\"content\\\":\\\"default\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"apple-mobile-web-app-title\\\",\\\"content\\\":\\\"Isaac Vazquez\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"application-name\\\",\\\"content\\\":\\\"Isaac Vazquez Portfolio\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"format-detection\\\",\\\"content\\\":\\\"telephone=no, date=no, email=no, address=no\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"msapplication-TileColor\\\",\\\"content\\\":\\\"#2563EB\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"msapplication-config\\\",\\\"content\\\":\\\"/browserconfig.xml\\\"}],[\\\"$\\\",\\\"link\\\",