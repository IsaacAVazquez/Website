416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"Providers\"]\n3:I[4665,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"StaticHeader\"]\n4:I[9644,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"ConditionalLayout\"]\n5:I[7121,[],\"\"]\n6:I[4581,[],\"\"]\n7:I[3693,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"2159\",\"static/chunks/2159-a2185eb42de1551d.js\",\"4345\",\"static/chunks/app/not-found-db6358576148c4d6.js\"],\"default\"]\n9:I[484,[],\"OutletBoundary\"]\na:\"$Sreact.suspense\"\nc:I[484,[],\"ViewportBoundary\"]\ne:I[484,[],\"MetadataBoundary\"]\n10:I[7123,[],\"\"]\n:HL[\"/_next/static/media/bb3ef058b751a6ad-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/css/15ee1b5f957de41a.css\",\"style\"]\n:HL[\"/_next/static/css/51be877e094ecfa4.css\",\"style\"]\n0:{\"P\":null,\"b\":\"ooiPNaC4xMZGBCIMNF3cX\",\"c\":[\"\",\"writing\",\"mastering-fantasy-football-analytics\"],\"q\":\"\",\"i\":false,\"f\":[[[\"\",{\"children\":[\"writing\",{\"children\":[[\"slug\",\"mastering-fantasy-football-analytics\",\"d\"],{\"children\":[\"__PAGE__\",{}]}]}]},\"$undefined\",\"$undefined\",true],[[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/css/15ee1b5f957de41a.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}],[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_ne