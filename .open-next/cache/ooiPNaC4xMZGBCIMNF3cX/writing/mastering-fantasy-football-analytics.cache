\"children\":\"$Lf\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}],false]],\"m\":\"$undefined\",\"G\":[\"$10\",[]],\"S\":true}\n11:T58e,{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"@id\":\"https://isaacavazquez.com/writing/mastering-fantasy-football-analytics#article\",\"headline\":\"Mastering Fantasy Football Analytics: A Data-Driven Approach to Winning\",\"description\":\"Master fantasy football through data analytics, visualization, and machine learning. Build advanced tools and gain competitive advantages with data science techniques.\",\"url\":\"https://isaacavazquez.com/writing/mastering-fantasy-football-analytics\",\"datePublished\":\"2025-01-24\",\"dateModified\":\"2025-01-24\",\"inLanguage\":\"en-US\",\"isAccessibleForFree\":true,\"image\":[\"https://isaacavazquez.com/og-image.png\"],\"author\":{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"@id\":\"https://isaacavazquez.com#person\",\"name\":\"Isaac Vazquez\",\"alternateName\":\"Isaac Vazquez\",\"description\":\"Product Manager and UC Berkeley Haas MBA Candidate with 5+ years building SaaS products reaching 60M+ users. Case studies, product thinking, and PM frameworks.\",\"url\":\"https://isaacavazquez.com\",\"image\":\"https://isaacavazquez.com/opengraph-image\",\"sameAs\":[\"https://linkedin.com/in/isaac-vazquez\",\"https://github.com/IsaacAVazquez\"],\"jobTitle\":\"Technical Product Manager & UC Berkeley MBA Candidate\"},\"articleSection\":\"Fantasy Football\",\"wordCount\":7980,\"keywords\":\"fantasy football analytics, sports data science, fantasy football tools, data visualization, machine learning fantasy, Austin fantasy football\"}8:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"@id\\\":\\\"https://isaacavazquez.com#breadcrumb\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\