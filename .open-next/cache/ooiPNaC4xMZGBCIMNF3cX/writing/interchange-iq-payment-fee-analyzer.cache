_time\\\",\\\"content\\\":\\\"2026-04-02\\\"}],[\\\"$\\\",\\\"link\\\",\\\"15\\\",{\\\"rel\\\":\\\"canonical\\\",\\\"href\\\":\\\"https://isaacavazquez.com/writing/interchange-iq-payment-fee-analyzer\\\"}],[\\\"$\\\",\\\"link\\\",\\\"16\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"en-US\\\",\\\"href\\\":\\\"https://isaacavazquez.com/writing/interchange-iq-payment-fee-analyzer\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"17\\\",{\\\"name\\\":\\\"format-detection\\\",\\\"content\\\":\\\"telephone=no, address=no, email=no\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"18\\\",{\\\"property\\\":\\\"og:title\\\",\\\"content\\\":\\\"Isaac Vazquez – Interchange IQ: A Payment Processor Fee Analyzer Built on Real Interchange Data\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"19\\\",{\\\"property\\\":\\\"og:description\\\",\\\"content\\\":\\\"See how Interchange IQ models payment processing costs across major processors using published interchange data, live fee comparison inputs, and breakeven analysis.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"20\\\",{\\\"property\\\":\\\"og:url\\\",\\\"content\\\":\\\"https://isaacavazquez.com/writing/interchange-iq-payment-fee-analyzer\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"21\\\",{\\\"property\\\":\\\"og:site_name\\\",\\\"content\\\":\\\"Isaac Vazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"22\\\",{\\\"property\\\":\\\"og:locale\\\",\\\"content\\\":\\\"en_US\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"23\\\",{\\\"property\\\":\\\"og:image\\\",\\\"content\\\":\\\"https://isaacavazquez.com/opengraph-image\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"24\\\",{\\\"property\\\":\\\"og:image:width\\\",\\\"content\\\":\\\"1200\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"25\\\",{\\\"property\\\":\\\"og:image:height\\\",\\\"content\\\":\\\"630\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"26\\\",{\\\"property\\\":\\\"og:image:alt\\\",\\\"content\\\":\\\"Isaac Vazquez - Technical Product Manager \\u0026 UC Berkeley Haas MBA Candidate\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"27\\\",{\\\"property\\\":\\\"og:type\\\",\\\"content\\\":\\\"website\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"28\\\",{\\\"name\\\":\\\"twitter:card\\\",\\\"content\\\":\\\"summary_large_image\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"29\\\",{\\\"name\\\":\\\"twitter:site\\\",\\\"content\\\":\\\"@isaacvazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"30\\\",{\\\"name\\\":\\\"twitter:creator\\\",\\\"content\\\":\\\"@isaacvazquez\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"31\\\",{\\\"name\\\":\\\"twitter:title\\\",\\\"content\\\":\\\"Isaac Vazquez – Interchange IQ: A Payment Processor Fee Analyzer Built on Real Interchange Data\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"32\\\",{\\\"name\\\":\\\"twitter:description\\\",\\\"content\\\":\\\"See how Interchange IQ models payment processing costs across major processors using published interchange data, live fee comparison inputs, and breakeven analysis.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"33\\\",{\\\"name\\\":\\\"twitter:image\\\",\\\"content\\\":\\\"https://isaacavazquez.com/opengraph-image\\\"}],[\\\"$\\\",\\\"link\\\",\\\"34\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/favicon.png\\\"}],[\\\"$\\\",\\\"$L19\\\",\\\"35\\\",{}]]\\n\"])</script></body></html>","rsc":"1:\"$Sreact.fragment\"\n2:I[7106,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"Providers\"]\n3:I[4665,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"StaticHeader\"]\n4:I[9644,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chunks/8409-baa9df2477416543.js\",\"5856\",\"static/chunks/5856-817fbea2f02f29bd.js\",\"7177\",\"static/chunks/app/layout-be1124ffefb0122c.js\"],\"ConditionalLayout\"]\n5:I[7121,[],\"\"]\n6:I[4581,[],\"\"]\n7:I[3693,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"8409\",\"static/chu