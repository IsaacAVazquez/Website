azquez\"}],[\"$\",\"meta\",\"22\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"23\",{\"property\":\"og:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"meta\",\"24\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"25\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"26\",{\"property\":\"og:image:alt\",\"content\":\"Isaac Vazquez - Technical Product Manager & UC Berkeley Haas MBA Candidate\"}],[\"$\",\"meta\",\"27\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"28\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"29\",{\"name\":\"twitter:site\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"30\",{\"name\":\"twitter:creator\",\"content\":\"@isaacvazquez\"}],[\"$\",\"meta\",\"31\",{\"name\":\"twitter:title\",\"content\":\"Isaac Vazquez – QA Engineering in Silicon Valley - UC Berkeley MBA Insights | Isaac Vazquez\"}],[\"$\",\"meta\",\"32\",{\"name\":\"twitter:description\",\"content\":\"Deep dive into Silicon Valley QA engineering practices from a UC Berkeley Haas MBA perspective. Strategic insights on quality assurance in Bay Area innovation culture.\"}],[\"$\",\"meta\",\"33\",{\"name\":\"twitter:image\",\"content\":\"https://isaacavazquez.com/opengraph-image\"}],[\"$\",\"link\",\"34\",{\"rel\":\"icon\",\"href\":\"/favicon.png\"}],[\"$\",\"$L1d\",\"35\",{}]]\n","segmentData":{"/_tree":":HL[\"/_next/static/media/bb3ef058b751a6ad-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/css/15ee1b5f957de41a.css\",\"style\"]\n:HL[\"/_next/static/css/51be877e094ecfa4.css\",\"style\"]\n0:{\"buildId\":\"ooiPNaC4xMZGBCIMNF3cX\",\"tree\":{\"name\":\"\",\"paramType\":null,\"paramKey\":\"\",\"hasRuntimePrefetch\":false,\"slots\":{\"children\":{\"name\":\"writing\",\"paramT