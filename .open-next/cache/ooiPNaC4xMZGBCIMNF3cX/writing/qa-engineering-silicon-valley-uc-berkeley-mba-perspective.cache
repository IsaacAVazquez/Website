ture\\\"}\"])</script><script>self.__next_f.push([1,\"8:[[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"@id\\\\\\\":\\\\\\\"https://isaacavazquez.com#breadcrumb\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://isaacavazquez.com/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Writing\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://isaacavazquez.com/writing\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"QA Engineering in Silicon Valley: Insights from a UC Berkeley MBA Perspective\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://isaacavazquez.com/writing/qa-engineering-silicon-valley-uc-berkeley-mba-perspective\\\\\\\"}]}\\\"},\\\"suppressHydrationWarning\\\":true}],[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$11\\\"},\\\"suppressHydrationWarning\\\":true}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"min-h-screen py-16 sm:py-20 px-4 sm:px-6 lg:px-8\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"max-w-4xl mx-auto\\\",\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"mb-12\\\",\\\"children\\\":[[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4\\\",\\\"children\\\":\\\"QA Engineering in Silicon Valley: Insights from a UC Berkeley MBA Perspective\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-4 text-neutral-600 dark:text-neutral-400 mb-6\\\",\\\"children\\\":[[\\\"$\\\"