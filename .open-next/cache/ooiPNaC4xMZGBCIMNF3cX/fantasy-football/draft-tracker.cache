ounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/investments\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 12m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M9 8m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v10a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path><path d=\"M15 4m0 1a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1z\"></path></svg><span>Investments</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/resume\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M14 3v4a1 1 0 0 0 1 1h4\"></path><path d=\"M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z\"></path><path d=\"M9 9l1 0\"></path><path d=\"M9 13l6 0\"></path><path d=\"M9 17l6 0\"></path></svg><span>Resume</span></a></li><li><a class=\"flex min-h-[48px] items-center gap-3 rounded-xl px-4 py-3 text-base font-medium transition-colors text-[var(--text-secondary)] hover:bg-[var(--surface-secondary)] hover:text-[var(--text-primary)]\" href=\"/contact\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5 shrink-0\"><path d=\"M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z\"></path><path d=\"M3 7l9 6l9 -6\"></path></svg><span>Contact</span></a></li></ul></div></div></div></header><div class=\"min-h-screen\"><main id=\"main-content\" role=\"main\" aria-label=\"Portfolio Content\" tabindex=\"-1\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\"}</script><section class=\"min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(77,182,255,0.12),transparent_28%),linear-gradient(180deg,#09111f_0%,#0c1424_55%,#08111c_100%)] text-white\"><div class=\"mx-auto w-full max-w-[1520px] px-4 pb-14 pt-8 sm:px-6 sm:pb-16 sm:pt-10 lg:px-8 xl:px-10\"><div class=\"overflow-hidden rounded-[32px] border border-white/10 bg-white/5 shadow-[0_24px_80px_rgba(0,0,0,0.28)] backdrop-blur\"><div class=\"grid gap-8 border-b border-white/10 px-6 py-7 sm:px-8 sm:py-8 xl:grid-cols-[minmax(0,1.4fr)_320px] xl:items-end\"><div class=\"min-w-0\"><p class=\"text-[11px] font-semibold uppercase tracking-[0.22em] text-sky-300/85\">Draft Assistant</p><h1 class=\"mt-3 max-w-[15ch] text-4xl font-semibold tracking-tight text-white sm:text-5xl\">Manual draft tracking that actually stays usable.</h1><p class=\"mt-4 max-w-[68ch] text-sm leading-7 text-slate-300 sm:text-[0.98rem]\">Log every pick, keep the board on the same published snapshot as the public rankings, and keep your roster context visible without pretending to simulate the entire room.</p><div class=\"mt-5 flex flex-wrap items-center gap-3 text-sm text-slate-300\"><span class=\"rounded-full border border-white/10 bg-white/5 px-3 py-1.5\">Loading snapshot</span><span class=\"rounded-full border border-white/10 bg-white/5 px-3 py-1.5\">Updated <!-- -->Unavailable</span><span class=\"rounded-full border border-white/10 bg-white/5 px-3 py-1.5\">PPR<!-- --> scoring</span></div></div><div class=\"grid gap-3 rounded-[28px] border border-white/10 bg-[#0d1728]/80 p-4\"><a class=\"flex min-h-[52px] items-center justify-between rounded-2xl border border-sky-400/20 bg-sky-400/10 px-4 py-3 text-sm font-semibold text-white transition hover:border-sky-300/40 hover:bg-sky-300/10\" href=\"/fantasy-football\"><span>Back to rankings board</span><span aria-hidden=\"true\">↗</span></a><div class=\"grid gap-3 sm:grid-cols-3 xl:grid-cols-1\"><div class=\"rounded-2xl border border-white/10 bg-white/5 px-4 py-3\"><p class=\"text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400\">Progress</p><p class=\"mt-2 text-sm font-semibold text-white\">0<!-- --> picks logged</p></div><div class=\"rounded-2xl border border-white/10 bg-white/5 px-4 py-3\"><p class=\"text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400\">On clock</p><p class=\"mt-2 text-sm font-semibold text-white\">Your Turn</p></div><div class=\"rounded-2xl border border-white/10 bg-white/5 px-4 py-3\"><p class=\"text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400\">Storage</p><p class=\"mt-2 text-sm font-semibold text-white\">Local persistence enabled</p></div></div></div></div><div class=\"px-6 py-6 sm:px-8\"><div class=\"rounded-[28px] border border-white/10 bg-[#08111f]/90 p-5 sm:p-6\"><div class=\"border-b border-white/10 pb-4\"><p class=\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-400\">Draft Setup</p><h2 class=\"mt-2 text-2xl font-semibold text-white\">Configure the room before picks start.</h2><p class=\"mt-2 text-sm leading-7 text-slate-300\">Save your league settings once, then use the published snapshot board to log every pick as the room moves.</p></div><div class=\"mt-5 grid gap-4 md:grid-cols-2\"><label class=\"grid gap-2 text-sm\"><span class=\"font-medium text-slate-200\">League name</span><input class=\"min-h-[48px] rounded-2xl border border-white/10 bg-white/5 px-4 text-white outline-none placeholder:text-slate-500 focus:border-sky-300/40\" placeholder=\"Home league\" value=\"My Fantasy League\"/></label><label class=\"grid gap-2 text-sm\"><span class=\"font-medium text-slate-200\">Teams</span><select class=\"min-h-[48px] rounded-2xl border border-white/10 bg-white/5 px-4 text-white outline-none focus:border-sky-300/40\"><option value=\"8\" class=\"bg-slate-950\">8<!-- --> teams</option><option value=\"10\" class=\"bg-slate-950\" selected=\"\">10<!-- --> teams</option><option value=\"12\" class=\"bg-slate-950\">12<!-- --> teams</option><option value=\"14\" class=\"bg-slate-950\">14<!-- --> teams</option><option value=\"16\" class=\"bg-slate-950\">16<!-- --> teams</option></select></label><label class=\"grid gap-2 text-sm\"><span class=\"font-medium text-slate-200\">Your draft slot</span><select class=\"min-h-[48px] rounded-2xl border border-white/10 bg-white/5 px-4 text-white outline-none focus:border-sky-300/40\"><option value=\"1\" class=\"bg-slate-950\" selected=\"\">Pick <!-- -->1</option><option value=\"2\" class=\"bg-slate-950\">Pick <!-- -->2</option><option value=\"3\" class=\"bg-slate-950\">Pick <!-- -->3</option><option value=\"4\" class=\"bg-slate-950\">Pick <!-- -->4</option><option value=\"5\" class=\"bg-slate-950\">Pick <!-- -->5</option><option value=\"6\" class=\"bg-slate-950\">Pick <!-- -->6</option><option value=\"7\" class=\"bg-slate-950\">Pick <!-- -->7</option><option value=\"8\" class=\"bg-slate-950\">Pick <!-- -->8</option><option value=\"9\" class=\"bg-slate-950\">Pick <!-- -->9</option><option value=\"10\" class=\"bg-slate-950\">Pick <!-- -->10</option></select></label><label class=\"grid gap-2 text-sm\"><span class=\"font-medium text-slate-200\">Rounds</span><select class=\"min-h-[48px] rounded-2xl border border-white/10 bg-white/5 px-4 text-white outline-none focus:border-sky-300/40\"><option value=\"13\" class=\"bg-slate-950\">13<!-- --> rounds</option><option value=\"14\" class=\"bg-slate-950\">14<!-- --> rounds</option><option value=\"15\" class=\"bg-slate-950\" selected=\"\">15<!-- --> rounds</option><option value=\"16\" class=\"bg-slate-950\">16<!-- --> rounds</option><option value=\"17\" class=\"bg-slate-950\">17<!-- --> rounds</option><option value=\"18\" class=\"bg-slate-950\">18<!-- --> rounds</option></select></label></div><div class=\"mt-5 grid gap-4 md:grid-cols-2\"><div class=\"grid gap-2 text-sm\"><span class=\"font-medium text-slate-200\">Draft order</span><div class=\"grid gap-2 sm:grid-cols-2\"><button type=\"button\" class=\"rounded-2xl border px-4 py-3 text-left transition border-sky-300/40 bg-sky-300/10 text-white\"><span class=\"block text-sm font-semibold\">Snake</span><span class=\"mt-1 block text-xs text-slate-400\">Reverse order each round.</span></button><button type=\"button\" class=\"rounded-2xl border px-4 py-3 text-left transition border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:text-white\"><span class=\"block text-sm font-semibold\">Linear</span><span class=\"mt-1 block text-xs text-slate-400\">Same order every round.</span></button></div></div><div class=\"grid gap-2 text-sm\"><span class=\"font-medium text-slate-200\">Scoring</span><div class=\"grid gap-2\"><button type=\"button\" class=\"rounded-2xl border px-4 py-3 text-left transition border-emerald-300/40 bg-emerald-300/10 text-white\"><span class=\"block text-sm font-semibold\">PPR</span><span class=\"mt-1 block text-xs text-slate-400\">Best for reception-heavy leagues.</span></button><button type=\"button\" class=\"rounded-2xl border px-4 py-3 text-left transition border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:text-white\"><span class=\"block text-sm font-semibold\">Half PPR</span><span class=\"mt-1 block text-xs text-slate-400\">Balanced default for most home leagues.</span></button><button type=\"button\" class=\"rounded-2xl border px-4 py-3 text-left transition border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:text-white\"><span class=\"block text-sm font-semibold\">Standard</span><span class=\"mt-1 block text-xs text-slate-400\">Use when receptions do not score.</span></button></div></div></div><div class=\"mt-6 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-white/10 bg-white/[0.035] px-4 py-4\"><p class=\"text-sm text-slate-300\">The board will track <!-- -->10<!-- --> teams, <!-- -->15<!-- --> rounds, and highlight your turns from slot <!-- -->1<!-- -->.</p><button type=\"button\" class=\"min-h-[48px] rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100\">Start draft assistant</button></div></div></div></div><div class=\"mt-4 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-300\">Loading the published draft snapshot...</div></div></section><!--$--><!--/$--></main></div><footer role=\"contentinfo\" aria-label=\"Site footer\" data-footer-variant=\"inverse\" class=\"relative z-20 border-t border-white/10 bg-[linear-gradient(180deg,color-mix(in_srgb,var(--neutral-950)_95%,var(--color-primary)_5%)_0%,color-mix(in_srgb,var(--neutral-950)_98%,var(--surface-primary)_2%)_100%)]\"><div class=\"page-shell py-12 md:py-16\"><div class=\"rounded-[1.5rem] p-8 md:p-10 border border-white/10 bg-white/[0.04] shadow-[var(--shadow-lg)]\"><div class=\"flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between\"><div class=\"space-y-4\"><h2 class=\"max-w-2xl text-3xl font-bold tracking-tight md:text-4xl text-white\">Thanks for taking a look.</h2><p class=\"max-w-2xl text-lg leading-relaxed text-slate-300\">If a project stands out, I&#x27;d be happy to share more about the work or my background.</p></div><div class=\"flex flex-col gap-3 sm:flex-row\"><a class=\"inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl px-6 py-3 font-medium transition-colors bg-white text-slate-950 hover:bg-slate-100\" href=\"/portfolio\">View projects<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\"><path d=\"M5 12l14 0\"></path><path d=\"M13 18l6 -6\"></path><path d=\"M13 6l6 6\"></path></svg></a><a class=\"inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl border px-6 py-3 font-medium transiti