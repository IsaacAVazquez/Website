{
  "name": "isaac-vazquez-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "postbuild": "next-sitemap && node scripts/patch-nft-sharp.mjs",
    "start": "next start",
    "lint": "eslint src",
    "analyze": "ANALYZE=true npm run build",
    "build:analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "update:fantasy-rb": "tsx scripts/updateFantasyRBTiers.ts",
    "update:investments": ".venv/bin/python3 scripts/fetch_investments_data.py",
    "generate:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
