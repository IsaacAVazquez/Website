{
  "name": "isaac-vazquez-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "tsx scripts/updateFootballSnapshots.ts --league-only",
    "update:football": "tsx scripts/updateFootballSnapshots.ts",
    "build": "next build --webpack",
    "postbuild": "next-sitemap && node scripts/patch-nft-sharp.mjs",
    "start": "next start",
    "lint": "eslint src",
    "analyze": "ANALYZE=true npm run build",
    "build:analyze": "ANALYZE=true next build --webpack",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "update:premier-league": "tsx scripts/buildPremierLeagueSnapshot.ts",
    "update:fantasy": "tsx scripts/buildFantasyPositionData.ts && tsx scripts/buildFantasySnapshots.ts",
    "update:fantasy-rb": "tsx scripts/buildFantasyPositionData.ts && tsx scripts/buildFantasySnapshots.ts",
    "update:investments": ".venv/bin/python3 scripts/fetch_investments_data.py && tsx scripts/buildInvestmentsSnapshots.ts",
    "generate:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-auth": "^4.24.13",
    "next-seo": "^7.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@netlify/functions": "^5.1.5",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "msw": "^2.12.14",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack-bundle-analyzer": "^5.3.0"
  }
}
