    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.12.10",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
