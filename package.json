{
  "name": "isaac-vazquez-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "update:football": "tsx scripts/updateFootballSnapshots.ts",
    "build": "next build --webpack",
    "postbuild": "npm run generate:sitemap && node scripts/patch-nft-sharp.mjs",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit --pretty false",
    "analyze": "ANALYZE=true npm run build",
    "build:analyze": "ANALYZE=true next build --webpack",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:full": "E2E_FULL_MATRIX=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "update:premier-league": "tsx scripts/buildPremierLeagueSnapshot.ts",
    "update:la-liga": "tsx scripts/updateLaLigaSnapshot.ts",
    "update:mlb": "tsx scripts/updateMlbSnapshot.ts",
    "update:nba": "tsx scripts/updateNbaSnapshot.ts",
    "update:nfl": "tsx scripts/updateNflSnapshot.ts",
    "update:formula-1": "tsx scripts/buildFormula1Snapshot.ts",
    "update:golf": "tsx scripts/buildGolfSnapshot.ts",
    "update:earthquake": "tsx scripts/buildEarthquakeSnapshot.ts",
    "update:world-cup": "tsx scripts/buildWorldCupSnapshot.ts",
    "update:bay-area-transit": "tsx scripts/buildBayAreaTransitSnapshot.ts",
    "update:frontier-models": "tsx scripts/buildFrontierModelsSnapshot.ts",
    "update:polling": "tsx scripts/buildPollingSnapshot.ts",
    "update:github-trending": "tsx scripts/buildGitHubTrendingSnapshot.ts",
    "update:tech-startups": "tsx scripts/buildTechStartupSnapshot.ts",
    "update:score-pools": "tsx scripts/buildScorePoolsSnapshot.ts",
    "update:spacex": "tsx scripts/buildSpaceXSnapshot.ts",
    "update:spacex-data": "tsx scripts/buildSpaceXSnapshot.ts",
    "update:spacex-images": "tsx scripts/buildSpaceXImageSnapshots.ts",
    "update:fantasy": "tsx scripts/buildFantasyPositionData.ts && tsx scripts/buildFantasyAdpData.ts && tsx scripts/buildFantasySnapshots.ts",
    "update:investments": ".venv/bin/python3 scripts/fetch_investments_data.py && tsx scripts/buildInvestmentsSnapshots.ts",
    "update:article-images": "tsx scripts/buildArticleCoverImages.ts",
    "check:blog-dates": "tsx scripts/checkBlogDateReview.ts",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "generate:sitemap": "node scripts/generatePublicSitemap.mjs"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-slot": "^1.2.4",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/typography": "^0.5.20",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "next-seo": "^7.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-rehype": "^11.1.2",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@netlify/functions": "^5.1.5",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "25.5.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.1.0-canary-00f063c3-20260415",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.1",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "overrides": {
    "postcss": "$postcss",
    "svix": "1.92.2"
  }
}
